<UserControl x:Class="AuraClean.Views.LargeFileFinderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{DynamicResource AuraTextBright}">
                <Run Text="Large File " /><Run Text="Finder" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Find the biggest files on your drives so you can decide what to keep"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls Bar -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Drive/Folder Selection -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Scan Location" FontSize="11"
                               Foreground="{DynamicResource AuraTextMuted}" Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding Drives}"
                                  SelectedItem="{Binding SelectedDrive}"
                                  DisplayMemberPath="Display"
                                  Background="{DynamicResource AuraSurfaceLight}"
                                  Foreground="{DynamicResource AuraTextPrimary}"
                                  FontSize="13"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="1" Content="Browse"
                                Style="{StaticResource AuraGhostButton}"
                                Command="{Binding BrowseFolderCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>

                <!-- Min Size -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="Min. Size (MB)" FontSize="11"
                               Foreground="{DynamicResource AuraTextMuted}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding SizePresets}"
                              SelectedItem="{Binding MinimumSizeMB}"
                              Background="{DynamicResource AuraSurfaceLight}"
                              Foreground="{DynamicResource AuraTextPrimary}"
                              FontSize="13" Width="100"
                              IsEditable="True"
                              IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                </StackPanel>

                <!-- Scan Button -->
                <StackPanel Grid.Column="2" Margin="20,0,0,0" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource AuraPrimaryButton}"
                            Command="{Binding ScanCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            Padding="24,10">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Scan" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Cancel -->
                <StackPanel Grid.Column="3" Margin="8,0,0,0" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource AuraGhostButton}"
                            Command="{Binding CancelScanCommand}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                            Content="Cancel" Padding="16,10" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results Area -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Summary + Filter Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,8"
                  Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Stats -->
                <Border Grid.Column="0" Style="{StaticResource AuraGlassCard}"
                        Padding="14,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="File" Foreground="{StaticResource AuraAccentPurple}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding ResultCount}" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource AuraTextPrimary}" VerticalAlignment="Center" />
                        <TextBlock Text=" files" Foreground="{DynamicResource AuraTextSecondary}"
                                   VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AuraGlassCard}"
                        Padding="14,8" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Harddisk" Foreground="{StaticResource AuraWarning}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding FormattedTotalSize}" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource AuraTextPrimary}" VerticalAlignment="Center" />
                        <TextBlock Text=" total" Foreground="{DynamicResource AuraTextSecondary}"
                                   VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Category Filter -->
                <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding FilterCategory}"
                          Background="{DynamicResource AuraSurfaceLight}"
                          Foreground="{DynamicResource AuraTextPrimary}"
                          FontSize="12" Width="130" Margin="0,0,8,0" />

                <!-- Search -->
                <TextBox Grid.Column="3"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Filter by name or path..."
                         Background="{DynamicResource AuraSurfaceLight}"
                         Foreground="{DynamicResource AuraTextPrimary}"
                         FontSize="12" Padding="8,6" />

                <!-- Actions -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0">
                    <Border Background="{DynamicResource AuraSurfaceLight}" CornerRadius="8"
                            Padding="10,4" VerticalAlignment="Center" Margin="0,0,8,0"
                            Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Run Text="{Binding SelectedCount, Mode=OneWay}" Foreground="{StaticResource AuraAccentPurple}" FontWeight="SemiBold" />
                            <Run Text=" checked" Foreground="{DynamicResource AuraTextSecondary}" />
                            <Run Text=" (" Foreground="{DynamicResource AuraTextMuted}" />
                            <Run Text="{Binding FormattedSelectedSize, Mode=OneWay}" Foreground="{StaticResource AuraWarning}" />
                            <Run Text=")" Foreground="{DynamicResource AuraTextMuted}" />
                        </TextBlock>
                    </Border>
                    <Button Style="{StaticResource AuraGhostButton}"
                            Command="{Binding OpenFileLocationCommand}"
                            Content="Open Location" Padding="12,6" />
                    <Button Style="{StaticResource AuraGhostButton}"
                            Command="{Binding DeleteSelectedCommand}"
                            Foreground="{StaticResource AuraWarning}"
                            Content="Delete" Padding="12,6" Margin="4,0,0,0" />
                </StackPanel>
            </Grid>

            <!-- File DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding FilteredFiles}"
                      SelectedItem="{Binding SelectedFile}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      SelectionMode="Extended"
                      Background="Transparent"
                      Foreground="{DynamicResource AuraTextPrimary}"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource AuraBorderSubtle}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource AuraOverlayFaint}"
                      HeadersVisibility="Column">

                <DataGrid.Columns>
                    <!-- Checkbox Column -->
                    <DataGridTemplateColumn Width="42">
                        <DataGridTemplateColumn.Header>
                            <CheckBox IsChecked="{Binding DataContext.IsAllSelected, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      AutomationProperties.Name="Select All Large Files"
                                      HorizontalAlignment="Center"
                                      ToolTip="Select / Deselect All" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                          AutomationProperties.Name="Select Large File"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"
                                        IsReadOnly="True"
                                        Foreground="{DynamicResource AuraTextPrimary}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                <Setter Property="ToolTip" Value="{Binding FileName}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Size" Binding="{Binding FormattedSize}" Width="100"
                                        IsReadOnly="True"
                                        Foreground="{StaticResource AuraAccentTeal}"
                                        SortMemberPath="SizeBytes" />
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110"
                                        IsReadOnly="True"
                                        Foreground="{DynamicResource AuraTextSecondary}" />
                    <DataGridTextColumn Header="Modified" Binding="{Binding LastModified, StringFormat=yyyy-MM-dd}" Width="100"
                                        IsReadOnly="True"
                                        Foreground="{DynamicResource AuraTextSecondary}" />
                    <DataGridTextColumn Header="Directory" Binding="{Binding Directory}" Width="*"
                                        IsReadOnly="True"
                                        Foreground="{DynamicResource AuraTextMuted}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                <Setter Property="ToolTip" Value="{Binding Directory}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Scanning Indicator -->
            <StackPanel Grid.Row="1"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="48" Height="48"
                             Foreground="{StaticResource AuraAccentPurple}" />
                <TextBlock Text="{Binding ProgressCurrentDir}"
                           Foreground="{DynamicResource AuraTextSecondary}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,12,0,0"
                           TextTrimming="CharacterEllipsis" MaxWidth="400" />
                <TextBlock Foreground="{DynamicResource AuraTextMuted}" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Run Text="{Binding ProgressFilesScanned, Mode=OneWay}" />
                    <Run Text=" scanned, " />
                    <Run Text="{Binding ProgressFilesFound, Mode=OneWay}" />
                    <Run Text=" found" />
                </TextBlock>
            </StackPanel>

            <!-- Empty State -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasResults}" Value="False" />
                                    <Condition Binding="{Binding IsBusy}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="FileFindOutline" Width="48" Height="48"
                                         Foreground="{DynamicResource AuraTextMuted}"
                                         HorizontalAlignment="Center" />
                <TextBlock Text="Select a location and click Scan"
                           Foreground="{DynamicResource AuraTextMuted}"
                           FontSize="14" HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   AutomationProperties.LiveSetting="Polite"
                   Foreground="{DynamicResource AuraTextSecondary}"
                   FontSize="13" Margin="0,12,0,0" />
    </Grid>
</UserControl>
