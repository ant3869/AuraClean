<UserControl x:Class="AuraClean.Views.StartupManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{StaticResource AuraTextBright}">
                <Run Text="Startup " /><Run Text="Manager" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Control which programs launch at Windows startup — speed up your boot time."
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Stats Cards + Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Stat Cards -->
            <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                     UniformCornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Apps" Foreground="{StaticResource AuraAccentPurple}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AuraTextSecondary}">
                            <Run Text="Total: " />
                            <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{StaticResource AuraTextPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                     UniformCornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="{StaticResource AuraSuccess}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AuraTextSecondary}">
                            <Run Text="Enabled: " />
                            <Run Text="{Binding EnabledCount, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{StaticResource AuraSuccess}" />
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                     UniformCornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="MinusCircle" Foreground="{StaticResource AuraTextSecondary}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AuraTextSecondary}">
                            <Run Text="Disabled: " />
                            <Run Text="{Binding DisabledCount, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{StaticResource AuraTextPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                     UniformCornerRadius="10" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle" Foreground="{StaticResource AuraWarning}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AuraTextSecondary}">
                            <Run Text="High Impact: " />
                            <Run Text="{Binding HighImpactCount, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{StaticResource AuraWarning}" />
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>
            </WrapPanel>

            <!-- Search & Actions -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search startup programs..."
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         materialDesign:HintAssist.IsFloating="False"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Foreground="{StaticResource AuraTextPrimary}"
                         Margin="0,0,12,0" />

                <Button Grid.Column="1"
                        Content="Refresh"
                        Style="{StaticResource AuraOutlinedButton}"
                        Padding="16,8"
                        Command="{Binding LoadEntriesCommand}"
                        Margin="0,0,8,0" />

                <Button Grid.Column="2"
                        Style="{StaticResource AuraPrimaryButton}"
                        Padding="16,8"
                        Command="{Binding ToggleSelectedCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ToggleSwitch" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="TOGGLE" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource AuraOutlinedButton}"
                        BorderBrush="{StaticResource AuraWarning}"
                        Foreground="{StaticResource AuraWarning}"
                        Padding="16,8"
                        Command="{Binding DeleteSelectedCommand}"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Delete" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="DELETE" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="4"
                        Style="{StaticResource AuraOutlinedButton}"
                        BorderBrush="{StaticResource AuraWarning}"
                        Foreground="{StaticResource AuraWarning}"
                        Padding="12,8"
                        Command="{Binding DisableAllHighImpactCommand}"
                        ToolTip="Disable all high-impact startup items"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FlashOff" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="DISABLE HIGH IMPACT" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="5"
                        Style="{StaticResource AuraGhostButton}"
                        Foreground="{StaticResource AuraAccentTeal}"
                        Command="{Binding OpenFileLocationCommand}"
                        ToolTip="Open file location"
                        Padding="8,6"
                        Margin="4,0,0,0">
                    <materialDesign:PackIcon Kind="FolderOpen" />
                </Button>
            </Grid>
        </Grid>

        <!-- Startup Entries List -->
        <materialDesign:Card Grid.Row="2"
                             Background="{StaticResource AuraSurface}"
                             UniformCornerRadius="8"
                             Padding="0">
            <Grid>
                <!-- Loading overlay -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Value="0" Width="48" Height="48" />

                <ListView ItemsSource="{Binding FilteredEntries}"
                          SelectedItem="{Binding SelectedEntry}"
                          Background="Transparent"
                          Foreground="{StaticResource AuraTextPrimary}"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Status" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon
                                            Kind="{Binding IsEnabled, Converter={StaticResource BoolToVis}, ConverterParameter=Icon}"
                                            Width="18" Height="18">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Kind" Value="CheckCircle" />
                                                            <Setter Property="Foreground" Value="{StaticResource AuraSuccess}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Kind" Value="MinusCircle" />
                                                            <Setter Property="Foreground" Value="{StaticResource AuraTextSecondary}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" Width="200"
                                            DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Publisher" Width="160"
                                            DisplayMemberBinding="{Binding Publisher}" />
                            <GridViewColumn Header="Impact" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ImpactLabel}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Impact}" Value="High">
                                                            <Setter Property="Foreground" Value="{StaticResource AuraWarning}" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Impact}" Value="Medium">
                                                            <Setter Property="Foreground" Value="#FFB74D" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Impact}" Value="Low">
                                                            <Setter Property="Foreground" Value="{StaticResource AuraSuccess}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Source" Width="140"
                                            DisplayMemberBinding="{Binding Location}" />
                            <GridViewColumn Header="Command" Width="200"
                                            DisplayMemberBinding="{Binding Command}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </materialDesign:Card>

        <!-- Status Bar -->
        <materialDesign:Card Grid.Row="3"
                             Background="{StaticResource AuraSurfaceLight}"
                             UniformCornerRadius="6"
                             Padding="16,8"
                             Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="12" />
        </materialDesign:Card>
    </Grid>
</UserControl>
