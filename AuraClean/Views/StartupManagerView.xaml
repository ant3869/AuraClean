<UserControl x:Class="AuraClean.Views.StartupManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{StaticResource AuraAccentPurple}"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock FontSize="26" FontWeight="Light"
                           Foreground="{DynamicResource AuraTextBright}">
                    <Run Text="Startup " /><Run Text="Manager" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
            <TextBlock Text="Control which programs launch at Windows startup — speed up your boot time."
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Stats Cards + Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Stat Cards -->
            <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Apps" Foreground="{StaticResource AuraAccentPurple}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource AuraTextSecondary}">
                            <Run Text="Total: " />
                            <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AuraTextPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="{StaticResource AuraSuccess}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource AuraTextSecondary}">
                            <Run Text="Enabled: " />
                            <Run Text="{Binding EnabledCount, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{StaticResource AuraSuccess}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="MinusCircle" Foreground="{DynamicResource AuraTextSecondary}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource AuraTextSecondary}">
                            <Run Text="Disabled: " />
                            <Run Text="{Binding DisabledCount, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AuraTextPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AuraGlassCardCompact}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle" Foreground="{StaticResource AuraWarning}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource AuraTextSecondary}">
                            <Run Text="High Impact: " />
                            <Run Text="{Binding HighImpactCount, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{StaticResource AuraWarning}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Search & Actions -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search startup programs..."
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         materialDesign:HintAssist.IsFloating="False"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Foreground="{DynamicResource AuraTextPrimary}"
                         Margin="0,0,12,0" />

                <Button Grid.Column="1"
                        Content="Refresh"
                        Style="{StaticResource AuraOutlinedButton}"
                        Padding="16,8"
                        Command="{Binding LoadEntriesCommand}"
                        Margin="0,0,8,0" />

                <Button Grid.Column="2"
                        Style="{StaticResource AuraPrimaryButton}"
                        Padding="16,8"
                        Command="{Binding ToggleSelectedCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ToggleSwitch" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="TOGGLE" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource AuraOutlinedButton}"
                        BorderBrush="{StaticResource AuraWarning}"
                        Foreground="{StaticResource AuraWarning}"
                        Padding="16,8"
                        Command="{Binding DeleteSelectedCommand}"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Delete" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="DELETE" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="4"
                        Style="{StaticResource AuraOutlinedButton}"
                        BorderBrush="{StaticResource AuraWarning}"
                        Foreground="{StaticResource AuraWarning}"
                        Padding="12,8"
                        Command="{Binding DisableAllHighImpactCommand}"
                        ToolTip="Disable all high-impact startup items"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FlashOff" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="DISABLE HIGH IMPACT" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="5"
                        Style="{StaticResource AuraGhostButton}"
                        Foreground="{StaticResource AuraAccentTeal}"
                        Command="{Binding OpenFileLocationCommand}"
                        ToolTip="Open file location"
                        Padding="8,6"
                        Margin="4,0,0,0">
                    <materialDesign:PackIcon Kind="FolderOpen" />
                </Button>

                <!-- Selection count badge -->
                <Border Grid.Column="5" Margin="8,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding HasCheckedItems, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource AuraAccentPurple}" CornerRadius="10"
                                Padding="10,3" Margin="0,0,6,0">
                            <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                                <Run Text=" selected" />
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Startup Entries List -->
        <Border Grid.Row="2" Style="{StaticResource AuraGlassCardFlush}"
                CornerRadius="8">
            <Grid>
                <!-- Loading overlay -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Foreground="{StaticResource AuraAccentPurple}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Value="0" Width="48" Height="48" />

                <ListView ItemsSource="{Binding FilteredEntries}"
                          SelectedItem="{Binding SelectedEntry}"
                          Background="Transparent"
                          Foreground="{DynamicResource AuraTextPrimary}"
                          BorderThickness="0"
                          SelectionMode="Extended"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="40">
                                <GridViewColumn.Header>
                                    <CheckBox IsChecked="{Binding DataContext.IsAllSelected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              ToolTip="Select All" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Status" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon
                                            Kind="{Binding IsEnabled, Converter={StaticResource BoolToVis}, ConverterParameter=Icon}"
                                            Width="18" Height="18">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Kind" Value="CheckCircle" />
                                                            <Setter Property="Foreground" Value="{StaticResource AuraSuccess}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Kind" Value="MinusCircle" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AuraTextSecondary}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Publisher" Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Publisher}" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Publisher}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Impact" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon x:Name="ImpactIcon" Kind="CircleSmall" Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,2,0" />
                                            <TextBlock x:Name="ImpactText" Text="{Binding ImpactLabel}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Impact}" Value="High">
                                                                <Setter Property="Foreground" Value="{StaticResource AuraWarning}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Impact}" Value="Medium">
                                                                <Setter Property="Foreground" Value="{StaticResource AuraAmber}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Impact}" Value="Low">
                                                                <Setter Property="Foreground" Value="{StaticResource AuraSuccess}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Impact}" Value="High">
                                                <Setter TargetName="ImpactIcon" Property="Kind" Value="AlertCircle" />
                                                <Setter TargetName="ImpactIcon" Property="Foreground" Value="{StaticResource AuraWarning}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Impact}" Value="Medium">
                                                <Setter TargetName="ImpactIcon" Property="Kind" Value="Alert" />
                                                <Setter TargetName="ImpactIcon" Property="Foreground" Value="{StaticResource AuraAmber}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Impact}" Value="Low">
                                                <Setter TargetName="ImpactIcon" Property="Kind" Value="CheckCircle" />
                                                <Setter TargetName="ImpactIcon" Property="Foreground" Value="{StaticResource AuraSuccess}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Source" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Location}" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Location}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Command" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Command}" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Command}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasScanned}" Value="True" />
                                        <Condition Binding="{Binding TotalCount}" Value="0" />
                                        <Condition Binding="{Binding IsBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="RocketLaunchOutline"
                                             Width="48" Height="48"
                                             HorizontalAlignment="Center"
                                             Foreground="{StaticResource AuraAccentPurple}"
                                             Opacity="0.5" />
                    <TextBlock Text="No startup programs found"
                               FontSize="15" Margin="0,10,0,4"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AuraTextSecondary}" />
                    <TextBlock Text="No startup entries were detected on this system"
                               FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource AuraTextMuted}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Style="{StaticResource AuraGlassCardCompact}"
                CornerRadius="6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="12" />
        </Border>
    </Grid>
</UserControl>
