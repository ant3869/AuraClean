<UserControl x:Class="AuraClean.Views.EmptyFolderFinderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{StaticResource AuraTextBright}">
                <Run Text="Empty Folder " /><Run Text="Finder" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Find and remove empty directories cluttering your file system"
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Scan Paths Card -->
        <materialDesign:Card Grid.Row="1" Background="{StaticResource AuraSurface}"
                             UniformCornerRadius="14" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Scan Locations" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource AuraTextPrimary}" Margin="0,0,0,10" />

                <!-- Path list -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding ScanPaths}" Margin="0,0,0,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource AuraSurfaceLight}"
                                    CornerRadius="8" Padding="10,6" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Folder" Width="16" Height="16"
                                                             Foreground="{StaticResource AuraAccentTeal}"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12"
                                               Foreground="{StaticResource AuraTextSecondary}"
                                               VerticalAlignment="Center" Margin="8,0,0,0" />
                                    <Button Grid.Column="2" Style="{StaticResource AuraGhostButton}"
                                            Command="{Binding DataContext.RemovePathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="4,2" MinWidth="0" MinHeight="0">
                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add path controls -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource AuraOutlinedButton}"
                            Command="{Binding BrowseFolderCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            Padding="12,6" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderPlus" Width="16" Height="16"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Browse" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Style="{StaticResource AuraPrimaryButton}"
                            Command="{Binding ScanCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderSearch" Width="18" Height="18"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Scan for Empty Folders" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- Status Bar -->
        <materialDesign:Card Grid.Row="2" Background="{StaticResource AuraSurface}"
                             UniformCornerRadius="14" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"
                                             Foreground="{StaticResource AuraAccentTeal}"
                                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{StaticResource AuraTextSecondary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AuraAccentPurple}"
                           VerticalAlignment="Center" Margin="0,0,16,0"
                           Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                    <Run Text="{Binding TotalFound, Mode=OneWay}" />
                    <Run Text=" folders found" />
                </TextBlock>

                <Button Grid.Column="2" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding CancelScanCommand}"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cancel" Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cancel" Margin="4,0,0,0" FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- Results DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding EmptyFolders}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="{StaticResource AuraTextPrimary}"
                  FontSize="12"
                  Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        Width="40" Header="" />
                <DataGridTextColumn Binding="{Binding Name}" Header="Folder Name"
                                    Width="200" IsReadOnly="True"
                                    Foreground="{StaticResource AuraTextPrimary}" />
                <DataGridTextColumn Binding="{Binding ParentPath}" Header="Location"
                                    Width="*" IsReadOnly="True"
                                    Foreground="{StaticResource AuraTextSecondary}" />
                <DataGridTextColumn Binding="{Binding DisplayInfo}" Header="Info"
                                    Width="200" IsReadOnly="True"
                                    Foreground="{StaticResource AuraTextMuted}" />
                <DataGridTextColumn Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                    Header="Last Modified" Width="140" IsReadOnly="True"
                                    Foreground="{StaticResource AuraTextMuted}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasResults, Converter={StaticResource InverseBoolToVis}}">
            <materialDesign:PackIcon Kind="FolderRemove" Width="64" Height="64"
                                     Foreground="{StaticResource AuraTextMuted}"
                                     HorizontalAlignment="Center" Opacity="0.3" />
            <TextBlock Text="No empty folders found yet" FontSize="14"
                       Foreground="{StaticResource AuraTextMuted}"
                       HorizontalAlignment="Center" Margin="0,12,0,0"
                       Visibility="{Binding IsScanning, Converter={StaticResource InverseBoolToVis}}" />
            <ProgressBar IsIndeterminate="True" Width="200" Margin="0,12,0,0"
                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- Bottom Action Bar -->
        <Grid Grid.Row="4" Margin="0,16,0,0"
              Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0" Content="Select All"
                      IsChecked="{Binding SelectAll}"
                      Foreground="{StaticResource AuraTextSecondary}"
                      VerticalAlignment="Center" FontSize="12" />

            <Button Grid.Column="2" Style="{StaticResource AuraPrimaryButton}"
                    Command="{Binding DeleteSelectedCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                    Padding="20,10">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DeleteForever" Width="18" Height="18"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Delete Selected" Margin="8,0,0,0"
                               VerticalAlignment="Center" FontSize="13" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
