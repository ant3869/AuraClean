<UserControl x:Class="AuraClean.Views.FileShredderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             AllowDrop="True"
             Drop="OnFileDrop"
             DragOver="OnDragOver">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{StaticResource AuraTextBright}">
                <Run Text="File " /><Run Text="Shredder" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Securely delete files by overwriting data — making recovery impossible"
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- File List -->
            <materialDesign:Card Grid.Column="0" Background="{StaticResource AuraSurface}"
                                 UniformCornerRadius="16" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource AuraBorderSubtle}">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding IsAllSelected}"
                                          ToolTip="Select All" Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Files to Shred" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource AuraTextPrimary}"
                                           VerticalAlignment="Center" />
                                <Border Background="{StaticResource AuraAccentPurple}" CornerRadius="10"
                                        Padding="8,2" Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding HasCheckedItems, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                        <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                                        <Run Text=" selected" />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Add Files"
                                        Style="{StaticResource AuraGhostButton}"
                                        Command="{Binding AddFilesCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                        Margin="0,0,8,0" />
                                <Button Content="Add Folder"
                                        Style="{StaticResource AuraGhostButton}"
                                        Command="{Binding AddFolderCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                        Margin="0,0,8,0" />
                                <Button Content="Clear"
                                        Style="{StaticResource AuraGhostButton}"
                                        Command="{Binding ClearAllCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- File ListView -->
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Files}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="8">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center" Margin="0,0,8,0" />

                                    <materialDesign:PackIcon Grid.Column="1" Kind="FileDocument" Width="20" Height="20"
                                                             Foreground="{StaticResource AuraTextSecondary}"
                                                             VerticalAlignment="Center" Margin="0,0,12,0" />

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}"
                                                   Foreground="{StaticResource AuraTextPrimary}"
                                                   FontSize="13" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding FullPath}"
                                                   Foreground="{StaticResource AuraTextMuted}"
                                                   FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="3" Text="{Binding FormattedSize}"
                                               Foreground="{StaticResource AuraAccentTeal}"
                                               FontWeight="SemiBold" FontSize="13"
                                               VerticalAlignment="Center" Margin="12,0" />

                                    <Button Grid.Column="4"
                                            Style="{StaticResource AuraGhostButton}"
                                            Content="{materialDesign:PackIcon Kind=Close}"
                                            Padding="4" Foreground="{StaticResource AuraWarning}"
                                            Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Remove from list" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty State -->
                    <StackPanel Grid.Row="1"
                                x:Name="EmptyState"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <materialDesign:PackIcon Kind="ShieldLockOutline" Width="48" Height="48"
                                                 Foreground="{StaticResource AuraTextMuted}"
                                                 HorizontalAlignment="Center" />
                        <TextBlock Text="No files added yet"
                                   Foreground="{StaticResource AuraTextMuted}"
                                   FontSize="14" HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Drag &amp; drop files here, or click 'Add Files' / 'Add Folder'"
                                   Foreground="{StaticResource AuraTextMuted}"
                                   FontSize="12" HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Progress -->
                    <Border Grid.Row="2" Padding="16,12"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <ProgressBar Minimum="0" Maximum="{Binding ProgressTotal}"
                                         Value="{Binding ProgressCurrent}"
                                         Foreground="{StaticResource AuraWarning}"
                                         Height="4" />
                            <TextBlock Text="{Binding ProgressText}"
                                       Foreground="{StaticResource AuraTextSecondary}"
                                       FontSize="11" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </materialDesign:Card>

            <!-- Right Panel: Algorithm Choice + Shred Button + Results -->
            <StackPanel Grid.Column="2">
                <!-- Algorithm Selection -->
                <materialDesign:Card Background="{StaticResource AuraSurface}"
                                     UniformCornerRadius="16" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Shred Algorithm" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AuraTextPrimary}" Margin="0,0,0,12" />

                        <ListBox ItemsSource="{Binding Algorithms}"
                                 SelectedItem="{Binding SelectedAlgorithmOption}"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,2" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" CornerRadius="10" Padding="12,10"
                                                        Background="Transparent"
                                                        BorderBrush="{StaticResource AuraBorderSubtle}"
                                                        BorderThickness="1" Cursor="Hand">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse x:Name="Dot" Width="16" Height="16"
                                                                 Stroke="{StaticResource AuraTextMuted}"
                                                                 StrokeThickness="2" Fill="Transparent"
                                                                 VerticalAlignment="Center" Margin="0,0,10,0" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Foreground="{StaticResource AuraTextPrimary}"
                                                                       FontSize="13" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Description}"
                                                                       Foreground="{StaticResource AuraTextSecondary}"
                                                                       FontSize="11" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Passes, StringFormat={}{0}×}"
                                                                   Foreground="{StaticResource AuraAccentPurple}"
                                                                   FontWeight="Bold" FontSize="14"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AuraAccentPurple}" />
                                                        <Setter TargetName="Bd" Property="Background" Value="#0A7C5CFC" />
                                                        <Setter TargetName="Dot" Property="Fill" Value="{StaticResource AuraAccentPurple}" />
                                                        <Setter TargetName="Dot" Property="Stroke" Value="{StaticResource AuraAccentPurple}" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Shred Button -->
                <Button Style="{StaticResource AuraPrimaryButton}"
                        Command="{Binding ShredAllCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        HorizontalAlignment="Stretch"
                        Padding="0,16" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ShieldLock" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="SHRED FILES" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Results Card -->
                <materialDesign:Card Background="{StaticResource AuraSurface}"
                                     UniformCornerRadius="16" Padding="20"
                                     Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Shred Results" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AuraTextPrimary}" Margin="0,0,0,12" />

                        <Grid Margin="0,4">
                            <TextBlock Text="Files Shredded" Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding LastShredded}" HorizontalAlignment="Right"
                                       Foreground="{StaticResource AuraSuccess}" FontWeight="SemiBold" />
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="Failed" Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding LastFailed}" HorizontalAlignment="Right"
                                       Foreground="{StaticResource AuraWarning}" FontWeight="SemiBold" />
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="Data Overwritten" Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding FormattedBytesOverwritten}" HorizontalAlignment="Right"
                                       Foreground="{StaticResource AuraAccentPurple}" FontWeight="SemiBold" />
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Foreground="{StaticResource AuraTextSecondary}"
                   FontSize="13" Margin="0,16,0,0" />
    </Grid>
</UserControl>
