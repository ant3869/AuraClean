<UserControl x:Class="AuraClean.Views.SoftwareUpdaterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{StaticResource AuraTextBright}">
                <Run Text="Software " /><Run Text="Updater" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Keep installed software up-to-date via Windows Package Manager (winget)"
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Action Bar -->
        <materialDesign:Card Grid.Row="1" Background="{StaticResource AuraSurface}"
                             UniformCornerRadius="14" Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Check for Updates"
                            Command="{Binding CheckForUpdatesCommand}"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Background="{StaticResource AuraAccentTeal}"
                            Foreground="White" FontWeight="SemiBold"
                            Height="36" Padding="20,0"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <Button Content="Update Selected"
                            Command="{Binding UpdateSelectedCommand}"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Background="{StaticResource AuraAccentPurple}"
                            Foreground="White" FontWeight="SemiBold"
                            Height="36" Padding="20,0" Margin="12,0,0,0"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <Button Content="Select All"
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource AuraTextSecondary}"
                            Height="36" Margin="12,0,0,0" />

                    <Button Content="Deselect All"
                            Command="{Binding DeselectAllCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource AuraTextSecondary}"
                            Height="36" Margin="4,0,0,0" />
                </StackPanel>

                <!-- Progress indicator -->
                <ProgressBar IsIndeterminate="True" Margin="0,12,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Height="3" />
            </StackPanel>
        </materialDesign:Card>

        <!-- Results List -->
        <Border Grid.Row="2" Background="{StaticResource AuraSurface}"
                CornerRadius="14" Padding="4">
            <DataGrid ItemsSource="{Binding Programs}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="False"
                      Background="Transparent"
                      Foreground="{StaticResource AuraTextPrimary}"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource AuraBorderSubtle}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#08FFFFFF"
                      HeadersVisibility="Column"
                      FontSize="12.5">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="40" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Installed" Binding="{Binding InstalledVersion}" Width="120"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Available" Binding="{Binding AvailableVersion}" Width="120"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="80"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Status" Binding="{Binding UpdateStatus}" Width="90"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status Bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="12" VerticalAlignment="Center" />
            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource AuraTextMuted}">
                <Run Text="Outdated: " />
                <Run Text="{Binding OutdatedCount, Mode=OneWay}" FontWeight="SemiBold" />
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
