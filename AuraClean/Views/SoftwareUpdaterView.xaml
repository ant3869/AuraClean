<UserControl x:Class="AuraClean.Views.SoftwareUpdaterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{DynamicResource AuraTextBright}">
                <Run Text="Software " /><Run Text="Updater" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Check for newer versions of your installed programs and update them"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Action Bar -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Check for Updates"
                            Command="{Binding CheckForUpdatesCommand}"
                            Style="{StaticResource AuraSecondaryButton}"
                            Height="36" Padding="20,0"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <Button Content="Update Selected"
                            Command="{Binding UpdateSelectedCommand}"
                            Style="{StaticResource AuraPrimaryButton}"
                            Height="36" Padding="20,0" Margin="12,0,0,0"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <Button Content="Select All"
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource AuraGhostButton}"
                            Height="36" Margin="12,0,0,0" />

                    <Button Content="Deselect All"
                            Command="{Binding DeselectAllCommand}"
                            Style="{StaticResource AuraGhostButton}"
                            Height="36" Margin="4,0,0,0" />
                </StackPanel>

                <!-- Progress indicator -->
                <ProgressBar IsIndeterminate="True" Margin="0,12,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Height="3" />
            </StackPanel>
        </Border>

        <!-- Results List -->
        <Border Grid.Row="2" Background="{DynamicResource AuraSurface}"
                CornerRadius="14" Padding="4">
            <Grid>
                <DataGrid ItemsSource="{Binding Programs}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="False"
                      Background="Transparent"
                      Foreground="{DynamicResource AuraTextPrimary}"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource AuraBorderSubtle}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource AuraOverlaySubtle}"
                      HeadersVisibility="Column"
                      FontSize="12.5">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="40" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Installed" Binding="{Binding InstalledVersion}" Width="120"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Available" Binding="{Binding AvailableVersion}" Width="120"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="80"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Status" Binding="{Binding UpdateStatus}" Width="90"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

                <!-- Empty state: before first scan -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasScanned}" Value="False" />
                                        <Condition Binding="{Binding IsBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="PackageVariantPlus"
                                             Width="48" Height="48"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource AuraTextMuted}" />
                    <TextBlock Text="Check for software updates"
                               FontSize="15" Margin="0,10,0,4"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AuraTextSecondary}" />
                    <TextBlock Text="Click 'Check for Updates' to scan for outdated software"
                               FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource AuraTextMuted}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="12" VerticalAlignment="Center" />
            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource AuraTextMuted}">
                <Run Text="Outdated: " />
                <Run Text="{Binding OutdatedCount, Mode=OneWay}" FontWeight="SemiBold" />
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
