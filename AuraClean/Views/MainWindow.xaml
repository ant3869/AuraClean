<Window x:Class="AuraClean.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:AuraClean.ViewModels"
        xmlns:views="clr-namespace:AuraClean.Views"
        xmlns:converters="clr-namespace:AuraClean.Converters"
        Title="AuraClean"
        Icon="/Assets/icon.ico"
        Width="1280" Height="780"
        MinWidth="1050" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AuraBackground}"
        TextElement.Foreground="{DynamicResource AuraTextPrimary}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{StaticResource AuraFontFamily}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Keyboard shortcut badge — fades in on nav hover, monospace -->
        <Style x:Key="NavShortcutText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AuraFontFamilyMono}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource AuraTextMuted}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="Dashboard" />
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="ThreatScanner" />
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="Uninstaller" />
        <KeyBinding Key="D4" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="Cleaner" />
        <KeyBinding Key="D5" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="Memory" />
        <KeyBinding Key="D6" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="Browser" />
        <KeyBinding Key="D7" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="StorageMap" />
        <KeyBinding Key="D8" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="Startup" />
        <KeyBinding Key="D9" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="Shredder" />
        <KeyBinding Key="D0" Modifiers="Control" Command="{Binding NavigateToCommand}" CommandParameter="Settings" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="260" />
            <!-- Content -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource AuraBorder}" BorderThickness="0,0,1,0"
                Background="{DynamicResource AuraSidebarGradient}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Row="0" Margin="24,32,24,24">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/icon2.png"
                               Width="38" Height="38"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center" />
                        <StackPanel Margin="14,0,0,0">
                            <TextBlock FontSize="28" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <StaticResource ResourceKey="AuraGradientLogo" />
                                </TextBlock.Foreground>
                                <Run Text="Aura" /><Run Text="Clean" FontWeight="Light" />
                            </TextBlock>
                            <TextBlock Text="System Utility"
                                       FontSize="10"
                                       Foreground="{DynamicResource AuraTextMuted}"
                                       Margin="0,-1,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Gradient separator -->
                    <Rectangle Height="1.5" Margin="0,22,0,0" RadiusX="1" RadiusY="1" Opacity="0.7">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="{StaticResource AuraVioletColor}" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </StackPanel>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,4,0,0">
                    <StackPanel Margin="4,0">
                        <!-- ─── Top-level: always visible ─── -->
                        <RadioButton x:Name="NavDashboard"
                                     Style="{StaticResource AuraNavButton}"
                                     IsChecked="True"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="Dashboard">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center"
                                                             Foreground="{StaticResource AuraAccentPurple}" />
                                    <TextBlock Text="Dashboard" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                                <TextBlock Text="Ctrl+1" Style="{StaticResource NavShortcutText}" />
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="NavThreatScanner"
                                     Style="{StaticResource AuraNavButton}"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="ThreatScanner">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldSearch" Width="20" Height="20" VerticalAlignment="Center"
                                                             Foreground="{StaticResource AuraWarning}" />
                                    <TextBlock Text="Threat Scanner" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                                <TextBlock Text="Ctrl+2" Style="{StaticResource NavShortcutText}" />
                            </Grid>
                        </RadioButton>

                        <!-- ─── CLEANUP section (collapsible) ─── -->
                        <Button Command="{Binding ToggleCleanupCommand}"
                                AutomationProperties.Name="Toggle Cleanup section"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                HorizontalContentAlignment="Stretch"
                                Margin="10,14,10,2" Padding="18,6">
                            <Grid>
                                <TextBlock Text="C L E A N U P"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AuraTextMuted}"
                                           Opacity="0.8"
                                           VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="ChevronDown" Width="14" Height="14"
                                                         Foreground="{DynamicResource AuraTextMuted}"
                                                         Opacity="0.8"
                                                         HorizontalAlignment="Right" VerticalAlignment="Center"
                                                         RenderTransformOrigin="0.5,0.5">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <RotateTransform x:Name="CleanupChevronRotate" Angle="0" />
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                            </Grid>
                        </Button>

                        <StackPanel Visibility="{Binding IsCleanupExpanded, Converter={StaticResource BoolToVis}}">
                            <RadioButton x:Name="NavCleaner"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Cleaner">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Broom" Width="20" Height="20" VerticalAlignment="Center" />
                                        <TextBlock Text="System Cleaner" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="Ctrl+4" Style="{StaticResource NavShortcutText}" />
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavBrowser"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Browser">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Web" Width="20" Height="20" VerticalAlignment="Center" />
                                        <TextBlock Text="Privacy Clean" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="Ctrl+6" Style="{StaticResource NavShortcutText}" />
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavUninstaller"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Uninstaller">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DeleteForever" Width="20" Height="20" VerticalAlignment="Center" />
                                        <TextBlock Text="Uninstaller" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="Ctrl+3" Style="{StaticResource NavShortcutText}" />
                                </Grid>
                            </RadioButton>
                        </StackPanel>

                        <!-- ─── ANALYZE section (collapsible) ─── -->
                        <Button Command="{Binding ToggleAnalyzeCommand}"
                                AutomationProperties.Name="Toggle Analyze section"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                HorizontalContentAlignment="Stretch"
                                Margin="10,14,10,2" Padding="18,6">
                            <Grid>
                                <TextBlock Text="A N A L Y Z E"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AuraTextMuted}"
                                           Opacity="0.8"
                                           VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="ChevronDown" Width="14" Height="14"
                                                         Foreground="{DynamicResource AuraTextMuted}"
                                                         Opacity="0.8"
                                                         HorizontalAlignment="Right" VerticalAlignment="Center"
                                                         RenderTransformOrigin="0.5,0.5">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <RotateTransform x:Name="AnalyzeChevronRotate" Angle="0" />
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                            </Grid>
                        </Button>

                        <StackPanel Visibility="{Binding IsAnalyzeExpanded, Converter={StaticResource BoolToVis}}">
                            <RadioButton x:Name="NavStorage"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="StorageMap">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ChartDonut" Width="20" Height="20" VerticalAlignment="Center" />
                                        <TextBlock Text="Storage Map" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="Ctrl+7" Style="{StaticResource NavShortcutText}" />
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavDuplicates"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Duplicates">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentDuplicate" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="Duplicate Finder" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>

                        <!-- ─── OPTIMIZE section (collapsible, expanded by default) ─── -->
                        <Button Command="{Binding ToggleOptimizeCommand}"
                                AutomationProperties.Name="Toggle Optimize section"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                HorizontalContentAlignment="Stretch"
                                Margin="10,14,10,2" Padding="18,6">
                            <Grid>
                                <TextBlock Text="O P T I M I Z E"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AuraTextMuted}"
                                           Opacity="0.8"
                                           VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="ChevronDown" Width="14" Height="14"
                                                         Foreground="{DynamicResource AuraTextMuted}"
                                                         Opacity="0.8"
                                                         HorizontalAlignment="Right" VerticalAlignment="Center"
                                                         RenderTransformOrigin="0.5,0.5">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <RotateTransform x:Name="OptimizeChevronRotate" Angle="0" />
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                            </Grid>
                        </Button>

                        <StackPanel Visibility="{Binding IsOptimizeExpanded, Converter={StaticResource BoolToVis}}">
                            <RadioButton x:Name="NavMemory"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Memory">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Memory" Width="20" Height="20" VerticalAlignment="Center" />
                                        <TextBlock Text="RAM Booster" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="Ctrl+5" Style="{StaticResource NavShortcutText}" />
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavDiskOptimizer"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="DiskOptimizer">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Harddisk" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="Disk Optimizer" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavStartup"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Startup">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="RocketLaunch" Width="20" Height="20" VerticalAlignment="Center" />
                                        <TextBlock Text="Startup Manager" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="Ctrl+8" Style="{StaticResource NavShortcutText}" />
                                </Grid>
                            </RadioButton>
                        </StackPanel>

                        <!-- ─── UTILITIES section (collapsible, collapsed by default) ─── -->
                        <Button Command="{Binding ToggleUtilitiesCommand}"
                                AutomationProperties.Name="Toggle Utilities section"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                HorizontalContentAlignment="Stretch"
                                Margin="10,14,10,2" Padding="18,6">
                            <Grid>
                                <TextBlock Text="U T I L I T I E S"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AuraTextMuted}"
                                           Opacity="0.8"
                                           VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="ChevronDown" Width="14" Height="14"
                                                         Foreground="{DynamicResource AuraTextMuted}"
                                                         Opacity="0.8"
                                                         HorizontalAlignment="Right" VerticalAlignment="Center"
                                                         RenderTransformOrigin="0.5,0.5">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <RotateTransform x:Name="UtilitiesChevronRotate" Angle="0" />
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                            </Grid>
                        </Button>

                        <StackPanel Visibility="{Binding IsUtilitiesExpanded, Converter={StaticResource BoolToVis}}">
                            <RadioButton x:Name="NavLargeFiles"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="LargeFiles">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileFind" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="Large File Finder" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavShredder"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Shredder">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ShieldLock" Width="20" Height="20" VerticalAlignment="Center" />
                                        <TextBlock Text="File Shredder" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="Ctrl+9" Style="{StaticResource NavShortcutText}" />
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavSystemInfo"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="SystemInfo">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="System Info" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavQuarantine"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Quarantine">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldOff" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="Quarantine" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavSoftwareUpdater"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="SoftwareUpdater">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Update" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="Software Updater" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavFileRecovery"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="FileRecovery">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileRestore" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="File Recovery" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavEmptyFolders"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="EmptyFolders">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderRemove" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="Empty Folders" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavAppInstaller"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="AppInstaller">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PackageDown" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="App Installer" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavMonitor"
                                         Style="{StaticResource AuraNavButton}"
                                         Command="{Binding NavigateToCommand}"
                                         CommandParameter="Monitor">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CameraOutline" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="Install Monitor" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>

                        <!-- ─── Bottom-pinned: Settings & History ─── -->
                        <Rectangle Height="1" Margin="14,16,14,8" Opacity="0.3"
                                   Fill="{DynamicResource AuraBorder}" />

                        <RadioButton x:Name="NavHistory"
                                     Style="{StaticResource AuraNavButton}"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="History">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ClipboardTextClock" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="Cleanup History" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavSettings"
                                     Style="{StaticResource AuraNavButton}"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="Settings">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CogOutline" Width="20" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="Settings" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                                <TextBlock Text="Ctrl+0" Style="{StaticResource NavShortcutText}" />
                            </Grid>
                        </RadioButton>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="24,0,24,18">
                    <Rectangle Height="1" Margin="0,0,0,12" Opacity="0.3">
                        <Rectangle.Fill>
                            <SolidColorBrush Color="{StaticResource AuraBorderColor}" />
                        </Rectangle.Fill>
                    </Rectangle>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <materialDesign:PackIcon Kind="ShieldKey"
                                                 Width="14" Height="14"
                                                 Foreground="{StaticResource AuraSuccess}"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Administrator"
                                   Foreground="{StaticResource AuraSuccess}"
                                   FontSize="11"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{Binding AppVersion}"
                               Foreground="{DynamicResource AuraTextMuted}"
                               FontSize="10"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- View Content: switched by CurrentViewName -->
            <Grid Grid.Row="0">
                <!-- Dashboard View -->
                <views:DashboardView DataContext="{Binding}"
                                     Visibility="Collapsed"
                                     x:Name="DashboardContent" />

                <!-- Uninstaller View -->
                <views:UninstallerView DataContext="{Binding Uninstaller}"
                                       Visibility="Collapsed"
                                       x:Name="UninstallerContent" />

                <!-- Cleaner View -->
                <views:CleanerView DataContext="{Binding Cleaner}"
                                   Visibility="Collapsed"
                                   x:Name="CleanerContent" />

                <!-- Memory Boost View -->
                <views:MemoryBoostView DataContext="{Binding Memory}"
                                       Visibility="Collapsed"
                                       x:Name="MemoryContent" />

                <!-- Browser Cleaner View -->
                <views:BrowserCleanerView DataContext="{Binding BrowserCleaner}"
                                          Visibility="Collapsed"
                                          x:Name="BrowserContent" />

                <!-- Storage Map View -->
                <views:StorageMapView DataContext="{Binding DiskAnalyzer}"
                                      Visibility="Collapsed"
                                      x:Name="StorageMapContent" />

                <!-- Install Monitor View -->
                <views:InstallMonitorView DataContext="{Binding InstallMonitor}"
                                          Visibility="Collapsed"
                                          x:Name="MonitorContent" />

                <!-- Startup Manager View -->
                <views:StartupManagerView DataContext="{Binding StartupManager}"
                                          Visibility="Collapsed"
                                          x:Name="StartupContent" />

                <!-- Duplicate Finder View -->
                <views:DuplicateFinderView DataContext="{Binding DuplicateFinder}"
                                           Visibility="Collapsed"
                                           x:Name="DuplicatesContent" />

                <!-- File Shredder View -->
                <views:FileShredderView DataContext="{Binding FileShredder}"
                                        Visibility="Collapsed"
                                        x:Name="ShredderContent" />

                <!-- Large File Finder View -->
                <views:LargeFileFinderView DataContext="{Binding LargeFileFinder}"
                                           Visibility="Collapsed"
                                           x:Name="LargeFilesContent" />

                <!-- System Info View -->
                <views:SystemInfoView DataContext="{Binding SystemInfo}"
                                      Visibility="Collapsed"
                                      x:Name="SystemInfoContent" />

                <!-- Settings View -->
                <views:SettingsView DataContext="{Binding Settings}"
                                    Visibility="Collapsed"
                                    x:Name="SettingsContent" />

                <!-- Cleanup History View -->
                <views:CleanupHistoryView DataContext="{Binding CleanupHistory}"
                                          Visibility="Collapsed"
                                          x:Name="HistoryContent" />

                <!-- Quarantine View -->
                <views:QuarantineView DataContext="{Binding Quarantine}"
                                      Visibility="Collapsed"
                                      x:Name="QuarantineContent" />

                <!-- Threat Scanner View -->
                <views:ThreatScannerView DataContext="{Binding ThreatScanner}"
                                         Visibility="Collapsed"
                                         x:Name="ThreatScannerContent" />

                <!-- Software Updater View -->
                <views:SoftwareUpdaterView DataContext="{Binding SoftwareUpdater}"
                                           Visibility="Collapsed"
                                           x:Name="SoftwareUpdaterContent" />

                <!-- Disk Optimizer View -->
                <views:DiskOptimizerView DataContext="{Binding DiskOptimizer}"
                                         Visibility="Collapsed"
                                         x:Name="DiskOptimizerContent" />

                <!-- File Recovery View -->
                <views:FileRecoveryView DataContext="{Binding FileRecovery}"
                                        Visibility="Collapsed"
                                        x:Name="FileRecoveryContent" />

                <!-- Empty Folder Finder View -->
                <views:EmptyFolderFinderView DataContext="{Binding EmptyFolderFinder}"
                                              Visibility="Collapsed"
                                              x:Name="EmptyFoldersContent" />

                <!-- App Bundle Installer View -->
                <views:AppInstallerView DataContext="{Binding AppInstaller}"
                                        Visibility="Collapsed"
                                        x:Name="AppInstallerContent" />
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="1"
                    Background="{DynamicResource AuraSurface}"
                    BorderBrush="{DynamicResource AuraBorder}" BorderThickness="0,1,0,0"
                    Padding="20,7">
                <TextBlock Text="{Binding StatusBarText}"
                           AutomationProperties.LiveSetting="Polite"
                           Foreground="{DynamicResource AuraTextSecondary}"
                           FontSize="11.5" />
            </Border>
        </Grid>

        <!-- ═══ ONBOARDING OVERLAY (full-window) ═══ -->
        <views:OnboardingView DataContext="{Binding Onboarding}"
                               Visibility="Collapsed"
                               x:Name="OnboardingOverlay"
                               Grid.ColumnSpan="2"
                               Panel.ZIndex="100" />
    </Grid>
</Window>
