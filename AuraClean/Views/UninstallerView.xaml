<UserControl x:Class="AuraClean.Views.UninstallerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{StaticResource AuraTextBright}">
                <Run Text="Surgical " /><Run Text="Uninstaller" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Remove programs completely — including leftover files and registry keys."
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Search Bar & Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Search programs..."
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     materialDesign:HintAssist.IsFloating="False"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Foreground="{StaticResource AuraTextPrimary}"
                     Margin="0,0,12,0" />

            <Button Grid.Column="1"
                    Content="Refresh"
                    Style="{StaticResource AuraOutlinedButton}"
                    Padding="16,8"
                    Command="{Binding LoadProgramsCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="2"
                    Content="Uninstall"
                    Style="{StaticResource AuraOutlinedButton}"
                    BorderBrush="{StaticResource AuraWarning}"
                    Foreground="{StaticResource AuraWarning}"
                    Padding="16,8"
                    Command="{Binding UninstallSelectedCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="3"
                    Content="Deep Scan"
                    Style="{StaticResource AuraPrimaryButton}"
                    Padding="16,8"
                    Command="{Binding DeepScanCommand}" />
        </Grid>

        <!-- Program List -->
        <materialDesign:Card Grid.Row="2"
                             Background="{StaticResource AuraSurface}"
                             UniformCornerRadius="8"
                             Padding="0"
                             Margin="0,0,0,12">
            <Grid>
                <!-- Loading overlay -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Value="0"
                             Width="48" Height="48" />

                <ListView ItemsSource="{Binding FilteredPrograms}"
                          SelectedItem="{Binding SelectedProgram}"
                          Background="Transparent"
                          Foreground="{StaticResource AuraTextPrimary}"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="280"
                                            DisplayMemberBinding="{Binding DisplayName}" />
                            <GridViewColumn Header="Publisher" Width="180"
                                            DisplayMemberBinding="{Binding Publisher}" />
                            <GridViewColumn Header="Version" Width="100"
                                            DisplayMemberBinding="{Binding DisplayVersion}" />
                            <GridViewColumn Header="Size" Width="100"
                                            DisplayMemberBinding="{Binding FormattedSize}" />
                            <GridViewColumn Header="Installed" Width="110"
                                            DisplayMemberBinding="{Binding InstallDate}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </materialDesign:Card>

        <!-- Post-Uninstall Scan Results -->
        <Expander Grid.Row="3"
                  Header="{Binding PostUninstallJunk.Count, StringFormat='Leftovers Found ({0} items)'}"
                  Visibility="{Binding HasPostUninstallResults, Converter={StaticResource BoolToVis}}"
                  IsExpanded="True"
                  Foreground="{StaticResource AuraTextPrimary}"
                  Margin="0,0,0,12">
            <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                 UniformCornerRadius="8"
                                 Padding="8"
                                 MaxHeight="200">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PostUninstallJunk}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected}"
                                              Margin="0,0,8,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{StaticResource AuraTextPrimary}"
                                                   FontSize="13" />
                                        <TextBlock Text="{Binding Path}"
                                                   Foreground="{StaticResource AuraTextSecondary}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding FormattedSize}"
                                               Foreground="{StaticResource AuraAccentTeal}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </materialDesign:Card>
        </Expander>

        <!-- Leftover Cleanup Button -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       Foreground="{StaticResource AuraTextSecondary}"
                       VerticalAlignment="Center"
                       FontSize="13" />

            <Button Grid.Column="1"
                    Content="CLEAN LEFTOVERS"
                    Style="{StaticResource AuraPrimaryButton}"
                    Padding="16,8"
                    Command="{Binding CleanLeftoversCommand}"
                    Visibility="{Binding HasPostUninstallResults, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</UserControl>
