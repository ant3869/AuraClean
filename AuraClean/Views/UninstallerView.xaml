<UserControl x:Class="AuraClean.Views.UninstallerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{StaticResource AuraAccentPurple}"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock FontSize="26" FontWeight="Light"
                           Foreground="{DynamicResource AuraTextBright}">
                    <Run Text="Surgical " /><Run Text="Uninstaller" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
            <TextBlock Text="Remove programs completely — including leftover files and registry keys."
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Search Bar & Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Search programs..."
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     materialDesign:HintAssist.IsFloating="False"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Foreground="{DynamicResource AuraTextPrimary}"
                     Margin="0,0,12,0" />

            <Button Grid.Column="1"
                    Content="Refresh"
                    Style="{StaticResource AuraOutlinedButton}"
                    Padding="16,8"
                    Command="{Binding LoadProgramsCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="2"
                    Content="Uninstall"
                    Style="{StaticResource AuraOutlinedButton}"
                    BorderBrush="{StaticResource AuraWarning}"
                    Foreground="{StaticResource AuraWarning}"
                    Padding="16,8"
                    Command="{Binding UninstallSelectedCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="3"
                    Content="Deep Scan"
                    Style="{StaticResource AuraPrimaryButton}"
                    Padding="16,8"
                    Command="{Binding DeepScanCommand}" />

            <!-- Selection count badge -->
            <Border Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Visibility="{Binding HasCheckedItems, Converter={StaticResource BoolToVis}}">
                <Border Background="{StaticResource AuraAccentPurple}" CornerRadius="10"
                        Padding="10,3">
                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                        <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                        <Run Text=" selected" />
                    </TextBlock>
                </Border>
            </Border>
        </Grid>

        <!-- Program List -->
        <Border Grid.Row="2" Style="{StaticResource AuraGlassCardFlush}"
                CornerRadius="8" Margin="0,0,0,12">
            <Grid>
                <!-- Loading overlay -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Foreground="{StaticResource AuraAccentPurple}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Value="0"
                             Width="48" Height="48" />

                <ListView ItemsSource="{Binding FilteredPrograms}"
                          SelectedItem="{Binding SelectedProgram}"
                          Background="Transparent"
                          Foreground="{DynamicResource AuraTextPrimary}"
                          BorderThickness="0"
                          SelectionMode="Extended"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="40">
                                <GridViewColumn.Header>
                                    <CheckBox IsChecked="{Binding DataContext.IsAllSelected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              ToolTip="Select All" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" Width="280">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DisplayName}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Publisher" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Publisher}" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Publisher}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Version" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayVersion}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Size" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FormattedSize}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Installed" Width="110">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding InstallDate}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasScanned}" Value="True" />
                                        <Condition Binding="{Binding FilteredPrograms.Count}" Value="0" />
                                        <Condition Binding="{Binding IsBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="PackageVariantRemove"
                                             Width="48" Height="48"
                                             HorizontalAlignment="Center"
                                             Foreground="{StaticResource AuraAccentPurple}"
                                             Opacity="0.5" />
                    <TextBlock Text="No programs found"
                               FontSize="15" Margin="0,10,0,4"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AuraTextSecondary}" />
                    <TextBlock Text="Try adjusting your search filter or refresh the list"
                               FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource AuraTextMuted}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Post-Uninstall Scan Results -->
        <Expander Grid.Row="3"
                  Header="{Binding PostUninstallJunk.Count, StringFormat='Leftovers Found ({0} items)'}"
                  Visibility="{Binding HasPostUninstallResults, Converter={StaticResource BoolToVis}}"
                  IsExpanded="True"
                  Foreground="{DynamicResource AuraTextPrimary}"
                  Margin="0,0,0,12">
            <Border Style="{StaticResource AuraGlassCardCompact}"
                    CornerRadius="8" Padding="8" MaxHeight="200">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PostUninstallJunk}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected}"
                                              Margin="0,0,8,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{DynamicResource AuraTextPrimary}"
                                                   FontSize="13" />
                                        <TextBlock Text="{Binding Path}"
                                                   Foreground="{DynamicResource AuraTextSecondary}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding FormattedSize}"
                                               Foreground="{StaticResource AuraAccentTeal}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Expander>

        <!-- Leftover Cleanup Button -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       VerticalAlignment="Center"
                       FontSize="13" />

            <Button Grid.Column="1"
                    Content="CLEAN LEFTOVERS"
                    Style="{StaticResource AuraPrimaryButton}"
                    Padding="16,8"
                    Command="{Binding CleanLeftoversCommand}"
                    Visibility="{Binding HasPostUninstallResults, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</UserControl>
