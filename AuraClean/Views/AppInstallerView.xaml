<UserControl x:Class="AuraClean.Views.AppInstallerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers"
             xmlns:models="clr-namespace:AuraClean.Models">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{StaticResource AuraAccentPurple}"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock FontSize="26" FontWeight="Light"
                           Foreground="{DynamicResource AuraTextBright}">
                    <Run Text="App Bundle " /><Run Text="Installer" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
            <TextBlock Text="Select and install popular free &amp; open-source applications in one click"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Search & Filter Bar -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}"
                Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Border Grid.Column="0" Background="{DynamicResource AuraSurfaceLight}"
                        CornerRadius="8" Padding="10,0" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                                 Foreground="{DynamicResource AuraTextMuted}"
                                                 VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource AuraTextPrimary}"
                                 FontSize="13" VerticalAlignment="Center"
                                 Margin="8,0,0,0" Padding="0,6"
                                 materialDesign:HintAssist.Hint="Search applications..."
                                 materialDesign:HintAssist.IsFloating="False"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden" />
                    </Grid>
                </Border>

                <!-- Category filter -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Width="180" FontSize="12"
                          Margin="0,0,12,0"
                          materialDesign:HintAssist.Hint="Category"
                          materialDesign:HintAssist.IsFloating="False" />

                <!-- Select/Deselect buttons -->
                <Button Grid.Column="2" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding SelectAllCommand}"
                        IsEnabled="{Binding IsInstalling, Converter={StaticResource InverseBoolConverter}}"
                        Padding="10,6" Margin="0,0,6,0" MinWidth="0">
                    <TextBlock Text="Select All" FontSize="11" />
                </Button>

                <Button Grid.Column="3" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding DeselectAllCommand}"
                        IsEnabled="{Binding IsInstalling, Converter={StaticResource InverseBoolConverter}}"
                        Padding="10,6" MinWidth="0">
                    <TextBlock Text="Clear All" FontSize="11" />
                </Button>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Style="{StaticResource AuraGlassCard}"
                Padding="14" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"
                                             Foreground="{StaticResource AuraAccentTeal}"
                                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               AutomationProperties.LiveSetting="Polite"
                               Foreground="{DynamicResource AuraTextSecondary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Selected count badge -->
                <Border Grid.Column="1" Background="{DynamicResource AuraSurfaceElevated}"
                        CornerRadius="{StaticResource AuraRadiusL}" Padding="12,4" Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <TextBlock FontSize="12" Foreground="{StaticResource AuraAccentPurple}">
                        <Run Text="{Binding SelectedCount, Mode=OneWay}" FontWeight="SemiBold" />
                        <Run Text=" selected" />
                    </TextBlock>
                </Border>

                <!-- Cancel button (visible during install) -->
                <Button Grid.Column="2" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding CancelInstallCommand}"
                        Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cancel" Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cancel" Margin="4,0,0,0" FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Progress bar overlay during install -->
        <ProgressBar Grid.Row="2" Value="{Binding OverallProgress}" Maximum="100"
                     Height="3" VerticalAlignment="Bottom" Margin="14,0,14,0"
                     Foreground="{StaticResource AuraAccentPurple}"
                     Background="Transparent"
                     Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}" />

        <!-- App Grid -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Apps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:BundleApp}">
                        <Border x:Name="CardBorder" Width="270" Margin="0,0,12,12"
                                CornerRadius="{StaticResource AuraRadiusL}" Padding="16"
                                BorderThickness="1.5" Cursor="Hand"
                                Background="{DynamicResource AuraSurface}"
                                BorderBrush="{DynamicResource AuraBorderSubtle}"
                                Focusable="True"
                                KeyboardNavigation.IsTabStop="True"
                                FocusVisualStyle="{StaticResource AuraFocusVisual}"
                                AutomationProperties.Name="{Binding Name}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.ToggleAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}" />
                                <KeyBinding Key="Enter"
                                            Command="{Binding DataContext.ToggleAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                <KeyBinding Key="Space"
                                            Command="{Binding DataContext.ToggleAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header: Icon + Name + Checkbox -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="36" Height="36"
                                            CornerRadius="8" Margin="0,0,10,0"
                                            Background="{DynamicResource AuraSurfaceElevated}">
                                        <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                 Width="20" Height="20"
                                                                 Foreground="{StaticResource AuraAccentTeal}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AuraTextBright}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                   Foreground="{DynamicResource AuraTextMuted}" />
                                    </StackPanel>

                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding IsSelected}"
                                              AutomationProperties.Name="Select Application"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False" />
                                </Grid>

                                <!-- Description -->
                                <TextBlock Grid.Row="1" Text="{Binding Description}"
                                           FontSize="11.5" TextWrapping="Wrap"
                                           Foreground="{DynamicResource AuraTextSecondary}"
                                           MaxHeight="36" TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,8" />

                                <!-- License badge -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Background="{DynamicResource AuraSurfaceElevated}"
                                            CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding License}" FontSize="9.5"
                                                   Foreground="{DynamicResource AuraTextMuted}" />
                                    </Border>
                                    <Border Background="{DynamicResource AuraSurfaceElevated}"
                                            CornerRadius="4" Padding="6,2" Margin="4,0,0,0"
                                            Visibility="{Binding IsPortable, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Portable" FontSize="9.5"
                                                   Foreground="{StaticResource AuraAmber}" />
                                    </Border>
                                </StackPanel>

                                <!-- Install status (visible during/after installation) -->
                                <Grid Grid.Row="3" Margin="0,6,0,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Downloading}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Installing}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Completed}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Failed}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <ProgressBar Grid.Row="0" Value="{Binding ProgressPercent}" Maximum="100"
                                                 Height="3" Margin="0,0,0,4">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                                <Setter Property="Foreground" Value="{StaticResource AuraAccentPurple}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Completed}">
                                                        <Setter Property="Foreground" Value="{StaticResource AuraSuccess}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Failed}">
                                                        <Setter Property="Foreground" Value="{StaticResource AuraWarning}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>

                                    <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                                               FontSize="10" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AuraTextMuted}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Completed}">
                                                        <Setter Property="Foreground" Value="{StaticResource AuraSuccess}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Failed}">
                                                        <Setter Property="Foreground" Value="{StaticResource AuraWarning}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Card border highlight when selected -->
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource AuraAccentPurple}" />
                                <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource AuraAccentPurpleSemi}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Completed}">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource AuraSuccess}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:InstallStatus.Failed}">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource AuraWarning}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding Apps.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=inverse}">
            <materialDesign:PackIcon Kind="ApplicationBraces" Width="64" Height="64"
                                     Foreground="{StaticResource AuraAccentPurple}"
                                     HorizontalAlignment="Center" Opacity="0.5" />
            <TextBlock Text="No applications match your search" FontSize="14"
                       Foreground="{DynamicResource AuraTextMuted}"
                       HorizontalAlignment="Center" Margin="0,12,0,0" />
        </StackPanel>

        <!-- Bottom Action Bar -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Summary stats during install -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}">
                <materialDesign:PackIcon Kind="DownloadCircle" Width="18" Height="18"
                                         Foreground="{StaticResource AuraAccentTeal}"
                                         VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock FontSize="12" Foreground="{DynamicResource AuraTextSecondary}"
                           VerticalAlignment="Center">
                    <Run Text="Installing: " />
                    <Run Text="{Binding CurrentAppName, Mode=OneWay}" FontWeight="SemiBold"
                         Foreground="{DynamicResource AuraTextPrimary}" />
                </TextBlock>
            </StackPanel>

            <!-- Install results -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding IsInstalling, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0"
                            Visibility="{Binding InstalledCount, Converter={StaticResource IntToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="CheckCircle" Width="16" Height="16"
                                             Foreground="{StaticResource AuraSuccess}"
                                             VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock FontSize="12" Foreground="{StaticResource AuraSuccess}" VerticalAlignment="Center">
                        <Run Text="{Binding InstalledCount, Mode=OneWay}" />
                        <Run Text=" installed" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding FailedCount, Converter={StaticResource IntToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="AlertCircle" Width="16" Height="16"
                                             Foreground="{StaticResource AuraWarning}"
                                             VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock FontSize="12" Foreground="{StaticResource AuraWarning}" VerticalAlignment="Center">
                        <Run Text="{Binding FailedCount, Mode=OneWay}" />
                        <Run Text=" failed" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Install button -->
            <Button Grid.Column="2" Style="{StaticResource AuraPrimaryButton}"
                    Command="{Binding InstallSelectedCommand}"
                    IsEnabled="{Binding IsInstalling, Converter={StaticResource InverseBoolConverter}}"
                    Padding="24,10">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DownloadMultiple" Width="18" Height="18"
                                             VerticalAlignment="Center" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="13">
                        <Run Text="Install Selected (" /><Run Text="{Binding SelectedCount, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
