<UserControl x:Class="AuraClean.Views.BrowserCleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers"
             xmlns:controls="clr-namespace:AuraClean.Views.Controls">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{StaticResource AuraAccentTeal}"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock FontSize="26" FontWeight="Light"
                           Foreground="{DynamicResource AuraTextBright}">
                    <Run Text="Privacy " /><Run Text="Clean" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
            <TextBlock Text="Clear browser caches, cookies, and tracking data to protect your privacy"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Options Row -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Cache" IsChecked="{Binding CleanCache}"
                              AutomationProperties.Name="Clean Cache"
                              Foreground="{DynamicResource AuraTextPrimary}" Margin="0,0,20,0" />
                    <CheckBox Content="SQLite Vacuum" IsChecked="{Binding VacuumDatabases}"
                              AutomationProperties.Name="Vacuum Databases"
                              Foreground="{DynamicResource AuraTextPrimary}" Margin="0,0,20,0" />
                    <CheckBox Content="Tracking Data" IsChecked="{Binding CleanTracking}"
                              AutomationProperties.Name="Clean Tracking Data"
                              Foreground="{DynamicResource AuraTextPrimary}" Margin="0,0,20,0" />

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0" />

                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  AutomationProperties.Name="Dry Run"
                                  IsChecked="{Binding IsDryRun}" Margin="8,0" />
                    <TextBlock Text="Dry Run" Foreground="{DynamicResource AuraTextSecondary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="SCAN"
                            Style="{StaticResource AuraPrimaryButton}"
                            Padding="24,8"
                            Command="{Binding ScanBrowsersCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="CLEAN"
                            Style="{StaticResource AuraOutlinedButton}"
                            Padding="24,8"
                            Command="{Binding CleanSelectedCommand}"
                            IsEnabled="{Binding HasResults}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Empty state -->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding HasResults}" Value="False" />
                                <Condition Binding="{Binding IsBusy}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <materialDesign:PackIcon Kind="Web"
                                     Width="48" Height="48"
                                     HorizontalAlignment="Center"
                                     Foreground="{StaticResource AuraAccentTeal}"
                                     Opacity="0.5" />
            <TextBlock Text="No browser data scanned"
                       FontSize="15" Margin="0,10,0,4"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AuraTextSecondary}" />
            <TextBlock Text="Click Scan to analyze browser caches and tracking data"
                       FontSize="12" HorizontalAlignment="Center"
                       Foreground="{DynamicResource AuraTextMuted}" />
            <Button Content="SCAN BROWSERS" Margin="0,16,0,0"
                    Style="{StaticResource AuraPrimaryButton}"
                    Command="{Binding ScanBrowsersCommand}"
                    HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Browser Results -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                <!-- Summary Cards — varied sizing -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Hero stat: Total Data Found -->
                    <Border Grid.Column="0" Style="{StaticResource AuraGlassCard}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource AuraAccentTeal}">
                        <StackPanel>
                            <TextBlock Text="Total Data Found" FontSize="12"
                                       Foreground="{DynamicResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding FormattedTotalSize}" FontSize="32" FontWeight="Bold"
                                       FontFamily="{DynamicResource AuraFontFamilyMono}"
                                       Foreground="{StaticResource AuraAccentPurple}" Margin="0,4,0,2" />
                            <TextBlock Text="across all detected browsers"
                                       FontSize="11" Foreground="{DynamicResource AuraTextMuted}" />
                        </StackPanel>
                    </Border>

                    <!-- Compact: Reclaimable Space -->
                    <Border Grid.Column="2" Style="{StaticResource AuraGlassCardCompact}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource AuraAccentTeal}"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Reclaimable" FontSize="11"
                                       Foreground="{DynamicResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding FormattedTotalSavings}" FontSize="22" FontWeight="Bold"
                                       FontFamily="{DynamicResource AuraFontFamilyMono}"
                                       Foreground="{StaticResource AuraSuccess}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Compact: Clean Targets -->
                    <Border Grid.Column="4" Style="{StaticResource AuraGlassCardCompact}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource AuraAccentTeal}"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Targets" FontSize="11"
                                       Foreground="{DynamicResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding TotalItemCount}" FontSize="22" FontWeight="Bold"
                                       FontFamily="{DynamicResource AuraFontFamilyMono}"
                                       Foreground="{StaticResource AuraAccentTeal}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Browser List -->
                <ItemsControl ItemsSource="{Binding BrowserResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AuraGlassCard}"
                                    Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              AutomationProperties.Name="Select Browser Result"
                                              VerticalAlignment="Center" Margin="0,0,12,0" />

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding BrowserName}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AuraTextPrimary}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock FontSize="12" Foreground="{DynamicResource AuraTextSecondary}">
                                                <Run Text="{Binding CacheItemCount, Mode=OneWay}" />
                                                <Run Text=" cache items · " />
                                                <Run Text="{Binding VacuumTargetCount, Mode=OneWay}" />
                                                <Run Text=" databases · " />
                                                <Run Text="{Binding TrackingItemCount, Mode=OneWay}" />
                                                <Run Text=" tracking items" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding FormattedSize}"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{StaticResource AuraAccentPurple}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   AutomationProperties.LiveSetting="Polite"
                   Foreground="{DynamicResource AuraTextSecondary}"
                   FontSize="13" Margin="0,12,0,0" TextWrapping="Wrap" />

        <!-- Post-Action Result Card -->
        <controls:ResultCard x:Name="BrowserResultCard" Grid.Row="4" />
    </Grid>
</UserControl>
