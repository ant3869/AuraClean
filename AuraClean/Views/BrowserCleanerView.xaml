<UserControl x:Class="AuraClean.Views.BrowserCleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{StaticResource AuraTextBright}">
                <Run Text="Privacy " /><Run Text="Clean" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Deep cache purge, SQLite vacuum, and tracking data removal for Chromium browsers"
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Options Row -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}"
                CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Cache" IsChecked="{Binding CleanCache}"
                              Foreground="{StaticResource AuraTextPrimary}" Margin="0,0,20,0" />
                    <CheckBox Content="SQLite Vacuum" IsChecked="{Binding VacuumDatabases}"
                              Foreground="{StaticResource AuraTextPrimary}" Margin="0,0,20,0" />
                    <CheckBox Content="Tracking Data" IsChecked="{Binding CleanTracking}"
                              Foreground="{StaticResource AuraTextPrimary}" Margin="0,0,20,0" />

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0" />

                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  IsChecked="{Binding IsDryRun}" Margin="8,0" />
                    <TextBlock Text="Dry Run" Foreground="{StaticResource AuraTextSecondary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="SCAN"
                            Style="{StaticResource AuraPrimaryButton}"
                            Padding="24,8"
                            Command="{Binding ScanBrowsersCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="CLEAN"
                            Style="{StaticResource AuraOutlinedButton}"
                            Padding="24,8"
                            Command="{Binding CleanSelectedCommand}"
                            IsEnabled="{Binding HasResults}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Browser Results -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                <!-- Summary Cards -->
                <WrapPanel Margin="0,0,0,16">
                    <Border Style="{StaticResource AuraGlassCardCompact}"
                            CornerRadius="12" Padding="16" Margin="0,0,12,0" Width="200">
                        <StackPanel>
                            <TextBlock Text="Total Data Found" FontSize="12"
                                       Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding FormattedTotalSize}" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource AuraAccentPurple}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AuraGlassCardCompact}"
                            CornerRadius="12" Padding="16" Margin="0,0,12,0" Width="200">
                        <StackPanel>
                            <TextBlock Text="Reclaimable Space" FontSize="12"
                                       Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding FormattedTotalSavings}" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource AuraSuccess}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AuraGlassCardCompact}"
                            CornerRadius="12" Padding="16" Width="200">
                        <StackPanel>
                            <TextBlock Text="Clean Targets" FontSize="12"
                                       Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding TotalItemCount}" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource AuraAccentTeal}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Browser List -->
                <ItemsControl ItemsSource="{Binding BrowserResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AuraGlassCard}"
                                    CornerRadius="12" Padding="16" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center" Margin="0,0,12,0" />

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding BrowserName}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AuraTextPrimary}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock FontSize="12" Foreground="{StaticResource AuraTextSecondary}">
                                                <Run Text="{Binding CacheItemCount, Mode=OneWay}" />
                                                <Run Text=" cache items · " />
                                                <Run Text="{Binding VacuumTargetCount, Mode=OneWay}" />
                                                <Run Text=" databases · " />
                                                <Run Text="{Binding TrackingItemCount, Mode=OneWay}" />
                                                <Run Text=" tracking items" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding FormattedSize}"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{StaticResource AuraAccentPurple}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="{StaticResource AuraTextSecondary}"
                   FontSize="13" Margin="0,12,0,0" TextWrapping="Wrap" />
    </Grid>
</UserControl>
