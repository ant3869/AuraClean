<UserControl x:Class="AuraClean.Views.StorageMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:views="clr-namespace:AuraClean.Views"
             xmlns:helpers="clr-namespace:AuraClean.Helpers">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{DynamicResource AuraTextBright}">
                <Run Text="Storage " /><Run Text="Map" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="See exactly what's using your disk space and where it's hiding"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Drive Selector -->
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Drives}"
                          SelectedItem="{Binding SelectedDrive}"
                          DisplayMemberPath="DisplayLabel"
                          materialDesign:HintAssist.Hint="Drive"
                          Width="280"
                          Foreground="{DynamicResource AuraTextPrimary}"
                          Margin="0,0,12,0" />

                <!-- Custom Path -->
                <TextBox Grid.Column="1"
                         materialDesign:HintAssist.Hint="Or enter a custom path..."
                         Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{DynamicResource AuraTextPrimary}"
                         Margin="0,0,12,0" />

                <!-- Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="ANALYZE"
                            Style="{StaticResource AuraPrimaryButton}"
                            Padding="24,8"
                            Command="{Binding AnalyzeCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="CANCEL"
                            Style="{StaticResource AuraOutlinedButton}"
                            BorderBrush="{StaticResource AuraWarning}"
                            Foreground="{StaticResource AuraWarning}"
                            Command="{Binding CancelAnalysisCommand}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Summary Stats -->
            <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Harddisk" Foreground="{StaticResource AuraAccentPurple}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Foreground="{DynamicResource AuraTextSecondary}" VerticalAlignment="Center">
                            <Run Text="Total: " />
                            <Run Text="{Binding FormattedTotalSize, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AuraTextPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="File" Foreground="{StaticResource AuraAccentTeal}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Foreground="{DynamicResource AuraTextSecondary}" VerticalAlignment="Center">
                            <Run Text="Files: " />
                            <Run Text="{Binding TotalFileCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AuraTextPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Folder" Foreground="{StaticResource AuraAccentPurple}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Foreground="{DynamicResource AuraTextSecondary}" VerticalAlignment="Center">
                            <Run Text="Dirs: " />
                            <Run Text="{Binding TotalDirCount, StringFormat={}{0:N0}, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AuraTextPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AuraGlassCardCompact}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Timer" Foreground="{StaticResource AuraAccentTeal}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Foreground="{DynamicResource AuraTextSecondary}" VerticalAlignment="Center">
                            <Run Text="Scan: " />
                            <Run Text="{Binding ScanDuration, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AuraTextPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Breadcrumb Navigation -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="{materialDesign:PackIcon Kind=ArrowUp}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Foreground="{StaticResource AuraAccentTeal}"
                        Command="{Binding NavigateUpCommand}"
                        AutomationProperties.Name="Navigate Up"
                        Width="32" Height="32" Padding="0" />
                <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text=" › " Foreground="{DynamicResource AuraTextSecondary}"
                                           VerticalAlignment="Center" />
                                <Button Content="{Binding Name}"
                                        Style="{StaticResource AuraGhostButton}"
                                        Foreground="{StaticResource AuraAccentTeal}"
                                        FontSize="13" Padding="4,2"
                                        Command="{Binding DataContext.NavigateToBreadcrumbCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Treemap Visualization -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <!-- Treemap (nested rectangles via ItemsControl) -->
                <Border Grid.Column="0" Background="{DynamicResource AuraSurface}"
                        CornerRadius="{StaticResource AuraRadiusL}" Padding="4" Margin="0,0,12,0">
                    <ItemsControl ItemsSource="{Binding TreemapData}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateToNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand" Margin="2">
                                    <Button.Template>
                                        <ControlTemplate>
                                            <Border Background="{Binding ColorIndex, Converter={StaticResource TreemapColorConverter}}"
                                                    CornerRadius="6" Padding="8,6"
                                                    MinWidth="80" MinHeight="50"
                                                    Width="{Binding SizePercent, Converter={x:Static views:StorageMapView.PercentToWidthConverter}}"
                                                    ToolTip="{Binding FullPath}">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="White" TextTrimming="CharacterEllipsis"
                                                               MaxWidth="200" />
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource AuraTextPrimary}">
                                                        <Run Text="{Binding FormattedSize, Mode=OneWay}" />
                                                        <Run Text=" (" /><Run Text="{Binding PercentLabel, Mode=OneWay}" /><Run Text=")" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Largest Files Panel -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource AuraGlassCard}"
                            Padding="12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Largest Files" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AuraAccentPurple}" Margin="0,0,0,8" />
                            <ListBox Grid.Row="1" ItemsSource="{Binding LargestFiles}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="12" Foreground="{DynamicResource AuraTextPrimary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding FullPath}" />
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedSize}"
                                                       FontSize="12" Foreground="{StaticResource AuraWarning}"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Largest Directories" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AuraAccentTeal}" Margin="0,0,0,8" />
                            <ListBox Grid.Row="1" ItemsSource="{Binding LargestDirs}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="12" Foreground="{DynamicResource AuraTextPrimary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding FullPath}" />
                                            <TextBlock Grid.Column="1" Text="{Binding FormattedSize}"
                                                       FontSize="12" Foreground="{StaticResource AuraAccentTeal}"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Progress / Loading -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Width="64" Height="64"
                         Foreground="{StaticResource AuraAccentPurple}" />
            <TextBlock Text="{Binding StatusMessage}" FontSize="14"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       HorizontalAlignment="Center" Margin="0,12,0,0"
                       TextWrapping="Wrap" MaxWidth="400" TextAlignment="Center" />
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   AutomationProperties.LiveSetting="Polite"
                   Foreground="{DynamicResource AuraTextSecondary}"
                   FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap" />
    </Grid>
</UserControl>
