<UserControl x:Class="AuraClean.Views.DiskOptimizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource AuraAccentTeal}"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock FontSize="26" FontWeight="Light"
                           Foreground="{DynamicResource AuraTextBright}">
                    <Run Text="Disk " /><Run Text="Optimizer" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
            <TextBlock Text="Speed up your drives — optimize hard disks and solid-state drives"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Action Bar -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Analyze Button -->
                <Button Grid.Column="0"
                        Style="{StaticResource AuraPrimaryButton}"
                        Command="{Binding AnalyzeDrivesCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Padding="20,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Analyze" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Optimize Button -->
                <Button Grid.Column="1"
                        Style="{StaticResource AuraSecondaryButton}"
                        Command="{Binding OptimizeDrivesCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Padding="20,10" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="RocketLaunch" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Optimize" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Select All -->
                <Button Grid.Column="2" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding SelectAllCommand}"
                        Content="Select All" Padding="14,8" Margin="16,0,0,0" />

                <!-- Deselect All -->
                <Button Grid.Column="3" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding DeselectAllCommand}"
                        Content="Deselect All" Padding="14,8" Margin="4,0,0,0" />

                <!-- Refresh -->
                <Button Grid.Column="4" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding RefreshDrivesCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Padding="14,8" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="Refresh" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Progress -->
                <ProgressBar Grid.Column="5" IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Margin="16,0,0,0" VerticalAlignment="Center"
                             Foreground="{StaticResource AuraAccentTeal}" />

                <!-- Cancel -->
                <Button Grid.Column="6" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                        Content="Cancel" Padding="14,8" Margin="8,0,0,0" />
            </Grid>
        </Border>

        <!-- Drive List -->
        <Grid Grid.Row="2">
            <DataGrid ItemsSource="{Binding Drives}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Background="Transparent"
                  Foreground="{DynamicResource AuraTextPrimary}"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource AuraBorderSubtle}"
                  RowBackground="Transparent"
                  AlternatingRowBackground="{StaticResource AuraOverlayFaint}"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <!-- Checkbox -->
                <DataGridTemplateColumn Width="42">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      AutomationProperties.Name="Select Drive"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Drive -->
                <DataGridTextColumn Header="Drive" Binding="{Binding DisplayName}" Width="*"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextPrimary}" />

                <!-- Type -->
                <DataGridTextColumn Header="Type" Binding="{Binding MediaTypeLabel}" Width="80"
                                    IsReadOnly="True"
                                    Foreground="{StaticResource AuraAccentTeal}" />

                <!-- File System -->
                <DataGridTextColumn Header="Format" Binding="{Binding FileSystem}" Width="80"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextSecondary}" />

                <!-- Total Size -->
                <DataGridTextColumn Header="Total" Binding="{Binding FormattedTotal}" Width="100"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextSecondary}" />

                <!-- Free Space -->
                <DataGridTextColumn Header="Free" Binding="{Binding FormattedFree}" Width="100"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextSecondary}" />

                <!-- Fragmentation -->
                <DataGridTemplateColumn Header="Fragmentation" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <ProgressBar Value="{Binding FragmentPercent, Mode=OneWay}"
                                             Maximum="100" Height="16"
                                             Background="{StaticResource AuraTrackBg}"
                                             Foreground="{StaticResource AuraWarning}" />
                                <TextBlock Text="{Binding FragmentPercent, StringFormat={}{0}%}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" Foreground="White" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Action -->
                <DataGridTextColumn Header="Action" Binding="{Binding OptimizeAction}" Width="120"
                                    IsReadOnly="True"
                                    Foreground="{StaticResource AuraAccentPurple}" />

                <!-- Status -->
                <DataGridTextColumn Header="Status" Binding="{Binding StatusMessage}" Width="200"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextSecondary}" />
            </DataGrid.Columns>
        </DataGrid>

            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasResults}" Value="False" />
                                    <Condition Binding="{Binding IsBusy}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="HarddiskRemove"
                                         Width="48" Height="48"
                                         HorizontalAlignment="Center"
                                         Foreground="{StaticResource AuraAccentTeal}"
                                         Opacity="0.5" />
                <TextBlock Text="No drives detected"
                           FontSize="15" Margin="0,10,0,4"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AuraTextSecondary}" />
                <TextBlock Text="Click Refresh to reload available drives"
                           FontSize="12" HorizontalAlignment="Center"
                           Foreground="{DynamicResource AuraTextMuted}" />
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="8,8"
                Background="{DynamicResource AuraSurfaceLight}" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           AutomationProperties.LiveSetting="Polite"
                           Foreground="{DynamicResource AuraTextSecondary}"
                           FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentOperation}"
                           AutomationProperties.LiveSetting="Polite"
                           Foreground="{StaticResource AuraAccentTeal}"
                           FontSize="12" VerticalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
