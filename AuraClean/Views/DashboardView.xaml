<UserControl x:Class="AuraClean.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers">

    <!-- HealthColorConverter and BoolToVis are defined globally in App.xaml -->

    <Grid Margin="32,24,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <TextBlock FontSize="{StaticResource AuraFontSizeDisplay}" FontWeight="Light"
                       FontFamily="{StaticResource AuraFontFamily}"
                       Foreground="{DynamicResource AuraTextBright}">
                <Run Text="System " /><Run Text="Health" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Monitor and optimize your system performance"
                       FontFamily="{StaticResource AuraFontFamily}"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="{StaticResource AuraFontSizeMD}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- ═══ STATUS STRIP — replaces hero gauge ═══ -->
        <Border Grid.Row="1"
                helpers:AnimationHelper.AnimateOnVisible="True"
                helpers:AnimationHelper.StaggerIndex="1"
                Background="{DynamicResource AuraSurface}"
                BorderBrush="{DynamicResource AuraBorder}" BorderThickness="1"
                CornerRadius="20" Padding="32,28" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Health score number — dominant hero typography -->
                <TextBlock Grid.Column="0"
                           Text="{Binding SystemHealthScore}"
                           FontFamily="{StaticResource AuraFontFamilyMono}"
                           FontSize="{StaticResource AuraFontSizeHero}" FontWeight="ExtraLight"
                           Foreground="{DynamicResource AuraTextBright}"
                           VerticalAlignment="Center" />

                <!-- Score context -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="{Binding HealthLabel}"
                               FontFamily="{StaticResource AuraFontFamily}"
                               FontSize="{StaticResource AuraFontSizeXL}" FontWeight="SemiBold"
                               Foreground="{Binding SystemHealthScore, Converter={StaticResource HealthColorConverter}}" />
                    <TextBlock Text="System Score"
                               FontFamily="{StaticResource AuraFontFamily}"
                               FontSize="{StaticResource AuraFontSizeCaption}"
                               Foreground="{DynamicResource AuraTextMuted}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Progress bar — horizontal replacement for circular gauge -->
                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="40,0">
                    <Border Background="{DynamicResource AuraBorderSubtle}"
                            CornerRadius="4" Height="8" />
                    <ProgressBar Value="{Binding SystemHealthScore}"
                                 Minimum="0" Maximum="100"
                                 Height="8"
                                 Foreground="{Binding SystemHealthScore, Converter={StaticResource HealthColorConverter}}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 helpers:AnimationHelper.SmoothProgress="True" />
                </Grid>

                <!-- Primary action -->
                <Button Grid.Column="3"
                        Style="{StaticResource AuraPrimaryButton}"
                        Command="{Binding QuickAnalyzeCommand}"
                        Padding="28,14"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White" />
                        <TextBlock Text="Analyze &amp; Clean" VerticalAlignment="Center"
                                   FontFamily="{StaticResource AuraFontFamily}"
                                   FontSize="{StaticResource AuraFontSizeMD}" FontWeight="SemiBold" Foreground="White" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ STAT CARDS — varied sizes ═══ -->
        <Grid Grid.Row="2" Margin="0,0,0,16"
              helpers:AnimationHelper.AnimateOnVisible="True"
              helpers:AnimationHelper.StaggerIndex="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Junk Found — hero stat (larger) -->
            <Border Grid.Column="0" Style="{StaticResource AuraGlassCard}" Padding="28,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource AuraAccentPurpleSemi}" CornerRadius="{StaticResource AuraRadiusL}"
                            Width="56" Height="56"
                            VerticalAlignment="Center" Margin="0,0,24,0">
                        <materialDesign:PackIcon Kind="DeleteSweep"
                                                 Width="28" Height="28"
                                                 Foreground="{StaticResource AuraAccentPurple}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Junk Found"
                                   FontFamily="{StaticResource AuraFontFamily}"
                                   FontSize="{StaticResource AuraFontSizeLabel}"
                                   Foreground="{DynamicResource AuraTextSecondary}" />
                        <TextBlock Text="{Binding Cleaner.FormattedTotalSize}"
                                   FontFamily="{StaticResource AuraFontFamilyMono}"
                                   FontSize="{StaticResource AuraFontSizeDisplay}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AuraTextBright}" />
                        <TextBlock Text="across system temp, cache &amp; logs"
                                   FontFamily="{StaticResource AuraFontFamily}"
                                   FontSize="{StaticResource AuraFontSizeCaption}"
                                   Foreground="{DynamicResource AuraTextMuted}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Programs Installed — compact (no icon badge for variety) -->
            <Border Grid.Column="2" Style="{StaticResource AuraGlassCard}" Padding="20,18">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="Apps"
                                                 Width="16" Height="16"
                                                 Foreground="{StaticResource AuraAccentTeal}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Programs"
                                   FontFamily="{StaticResource AuraFontFamily}"
                                   FontSize="{StaticResource AuraFontSizeLabel}"
                                   Foreground="{DynamicResource AuraTextSecondary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding Uninstaller.Programs.Count}"
                               FontFamily="{StaticResource AuraFontFamilyMono}"
                               FontSize="{StaticResource AuraFontSizeTitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AuraTextBright}" />
                </StackPanel>
            </Border>

            <!-- Last Cleaned — compact (no icon badge for variety) -->
            <Border Grid.Column="4" Style="{StaticResource AuraGlassCard}" Padding="20,18">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="ClockOutline"
                                                 Width="16" Height="16"
                                                 Foreground="{StaticResource AuraAmber}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Last Cleaned"
                                   FontFamily="{StaticResource AuraFontFamily}"
                                   FontSize="{StaticResource AuraFontSizeLabel}"
                                   Foreground="{DynamicResource AuraTextSecondary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding LastCleanedDisplay}"
                               FontFamily="{StaticResource AuraFontFamily}"
                               FontSize="{StaticResource AuraFontSizeLG}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AuraTextBright}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ SYSTEM INFO STRIP ═══ -->
        <Border Grid.Row="3"
                helpers:AnimationHelper.AnimateOnVisible="True"
                helpers:AnimationHelper.StaggerIndex="3"
                CornerRadius="{StaticResource AuraRadiusL}"
                Background="{DynamicResource AuraSurface}"
                BorderBrush="{DynamicResource AuraBorder}" BorderThickness="1"
                Padding="0" VerticalAlignment="Top">
                <Grid>
                    <!-- Subtle gradient top edge — monochromatic violet -->
                    <Rectangle Height="1" VerticalAlignment="Top" Opacity="0.5" RadiusX="6" RadiusY="6">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="{StaticResource AuraVioletColor}" Offset="0" />
                                <GradientStop Color="{StaticResource AuraVioletDarkColor}" Offset="0.6" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <UniformGrid Rows="1" Margin="6,12">
                        <!-- OS -->
                        <StackPanel Margin="16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <materialDesign:PackIcon Kind="MicrosoftWindows" Width="13" Height="13"
                                                         Foreground="{StaticResource AuraAccentPurple}"
                                                         Opacity="0.7"
                                                         VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="OS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AuraTextMuted}" />
                            </StackPanel>
                            <TextBlock Text="{Binding OsName}"
                                       Foreground="{DynamicResource AuraTextPrimary}"
                                       FontSize="11.5" TextTrimming="CharacterEllipsis" MaxWidth="240" />
                        </StackPanel>

                        <!-- CPU -->
                        <StackPanel Margin="16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <materialDesign:PackIcon Kind="Chip" Width="13" Height="13"
                                                         Foreground="{StaticResource AuraAccentTeal}"
                                                         Opacity="0.7"
                                                         VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="CPU" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AuraTextMuted}" />
                            </StackPanel>
                            <TextBlock Text="{Binding CpuName}"
                                       Foreground="{DynamicResource AuraTextPrimary}"
                                       FontSize="11.5" TextTrimming="CharacterEllipsis" MaxWidth="240" />
                        </StackPanel>

                        <!-- RAM -->
                        <StackPanel Margin="16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <materialDesign:PackIcon Kind="Memory" Width="13" Height="13"
                                                         Foreground="{StaticResource AuraAmber}"
                                                         Opacity="0.7"
                                                         VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="RAM" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AuraTextMuted}" />
                            </StackPanel>
                            <TextBlock Text="{Binding TotalRam}"
                                       Foreground="{DynamicResource AuraTextBright}"
                                       FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <!-- Uptime -->
                        <StackPanel Margin="16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <materialDesign:PackIcon Kind="TimerOutline" Width="13" Height="13"
                                                         Foreground="{StaticResource AuraAccentPurple}"
                                                         Opacity="0.7"
                                                         VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="UPTIME" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AuraTextMuted}" />
                            </StackPanel>
                            <TextBlock Text="{Binding SystemUptime}"
                                       Foreground="{DynamicResource AuraTextBright}"
                                       FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

        <!-- ═══ SECONDARY ACTIONS ═══ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="4">
                <Button Style="{StaticResource AuraGhostButton}"
                        Command="{Binding QuickCleanCommand}"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Broom" Width="16" Height="16"
                                                 Foreground="{StaticResource AuraAccentTeal}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="QUICK CLEAN" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource AuraGhostButton}"
                        Command="{Binding RunHealthCheckCommand}"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ShieldCheck" Width="16" Height="16"
                                                 Foreground="{StaticResource AuraAccentPurple}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="HEALTH CHECK" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource AuraGhostButton}"
                        Command="{Binding BoostMemoryCommand}"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="RocketLaunch" Width="16" Height="16"
                                                 Foreground="{StaticResource AuraAmber}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="BOOST RAM" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource AuraGhostButton}"
                        Command="{Binding NavigateToCommand}"
                        CommandParameter="StorageMap"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartDonut" Width="16" Height="16"
                                                 Foreground="{StaticResource AuraWarning}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="STORAGE MAP" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource AuraGhostButton}"
                        Command="{Binding UndoLastCleanCommand}"
                        Visibility="{Binding Cleaner.CanUndoLastClean, Converter={StaticResource BoolToVis}}"
                        ToolTip="{Binding Cleaner.LastCleanedSummary}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="UndoVariant" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="UNDO CLEAN" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
        </StackPanel>

        <!-- ═══ HEALTH CHECK STATUS ═══ -->
        <StackPanel Grid.Row="5" HorizontalAlignment="Center" Margin="0,8,0,0"
                    Visibility="{Binding IsHealthCheckRunning, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" Width="300" Height="4" Margin="0,0,0,6"
                         Foreground="{StaticResource AuraAccentPurple}" />
            <TextBlock Text="{Binding HealthCheckProgress}"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource AuraTextMuted}" FontSize="11"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="5" Text="{Binding HealthCheckSummary}"
                   AutomationProperties.LiveSetting="Polite"
                   HorizontalAlignment="Center" Margin="0,8,0,0"
                   Foreground="{DynamicResource AuraTextSecondary}" FontSize="12"
                   FontWeight="Medium" TextWrapping="Wrap" MaxWidth="500"/>

        <!-- ═══ CONTEXT MENU TOGGLE ═══ -->
        <StackPanel Grid.Row="6" HorizontalAlignment="Center" Margin="0,16,0,0" Orientation="Horizontal">
            <TextBlock Text="Explorer Context Menu:"
                       Foreground="{DynamicResource AuraTextMuted}" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="{Binding ContextMenuStatus}"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource AuraTextSecondary}" FontSize="11"
                       FontWeight="Medium" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>