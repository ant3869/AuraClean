<UserControl x:Class="AuraClean.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <UserControl.Resources>
        <converters:HealthScoreColorConverter x:Key="HealthColorConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="32,24,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock FontSize="28" FontWeight="Light"
                       Foreground="{StaticResource AuraTextBright}">
                <Run Text="System " /><Run Text="Health" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Monitor and optimize your system performance"
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="13" Margin="0,2,0,0" />
        </StackPanel>

        <!-- ═══ MAIN CONTENT: GAUGE + STATS ═══ -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- ── HEALTH GAUGE ── -->
            <Grid Grid.Row="0" Grid.Column="0" Width="280" Height="280">
                <!-- Outermost decorative ring — dashed, faint -->
                <Ellipse Width="270" Height="270"
                         Stroke="{StaticResource AuraBorder}" StrokeThickness="1"
                         StrokeDashArray="2 4"
                         Fill="Transparent" />

                <!-- Ambient glow behind the gauge -->
                <Ellipse Width="240" Height="240" Opacity="0.07">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="{StaticResource AuraVioletColor}" Offset="0.2" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Track ring -->
                <Ellipse Width="220" Height="220"
                         Stroke="{StaticResource AuraBorderSubtle}" StrokeThickness="14"
                         Fill="Transparent" />

                <!-- Progress arc -->
                <materialDesign:Card UniformCornerRadius="0" Background="Transparent"
                                     Width="250" Height="250">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Width="220" Height="220"
                                 Value="{Binding SystemHealthScore}"
                                 Minimum="0" Maximum="100"
                                 Foreground="{Binding SystemHealthScore, Converter={StaticResource HealthColorConverter}}"
                                 IsIndeterminate="False" />
                </materialDesign:Card>

                <!-- Inner decorative ring -->
                <Ellipse Width="190" Height="190"
                         Stroke="{StaticResource AuraBorder}" StrokeThickness="0.5"
                         Fill="Transparent" Opacity="0.5" />

                <!-- Center score -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding SystemHealthScore}"
                               FontSize="60" FontWeight="Light"
                               Foreground="{StaticResource AuraTextBright}"
                               HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#7C5CFC" BlurRadius="30"
                                              ShadowDepth="0" Opacity="0.15" />
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="{Binding HealthLabel}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{Binding SystemHealthScore, Converter={StaticResource HealthColorConverter}}"
                               HorizontalAlignment="Center"
                               Margin="0,-8,0,0" />
                </StackPanel>
            </Grid>

            <!-- ── STAT CARDS ── -->
            <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Width="300">

                <!-- Junk Found -->
                <Border CornerRadius="14" Padding="18"
                        Background="{StaticResource AuraSurface}"
                        BorderBrush="{StaticResource AuraBorder}" BorderThickness="1"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0E7C5CFC" CornerRadius="10"
                                Width="44" Height="44"
                                VerticalAlignment="Center" Margin="0,0,16,0">
                            <materialDesign:PackIcon Kind="DeleteSweep"
                                                     Width="22" Height="22"
                                                     Foreground="{StaticResource AuraAccentPurple}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Junk Found" FontSize="12"
                                       Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding Cleaner.FormattedTotalSize}"
                                       FontSize="22" FontWeight="SemiBold"
                                       Foreground="{StaticResource AuraTextBright}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Programs Installed -->
                <Border CornerRadius="14" Padding="18"
                        Background="{StaticResource AuraSurface}"
                        BorderBrush="{StaticResource AuraBorder}" BorderThickness="1"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0E00E5C3" CornerRadius="10"
                                Width="44" Height="44"
                                VerticalAlignment="Center" Margin="0,0,16,0">
                            <materialDesign:PackIcon Kind="Apps"
                                                     Width="22" Height="22"
                                                     Foreground="{StaticResource AuraAccentTeal}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Programs Installed" FontSize="12"
                                       Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding Uninstaller.Programs.Count}"
                                       FontSize="22" FontWeight="SemiBold"
                                       Foreground="{StaticResource AuraTextBright}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Last Cleaned -->
                <Border CornerRadius="14" Padding="18"
                        Background="{StaticResource AuraSurface}"
                        BorderBrush="{StaticResource AuraBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0EFFB74D" CornerRadius="10"
                                Width="44" Height="44"
                                VerticalAlignment="Center" Margin="0,0,16,0">
                            <materialDesign:PackIcon Kind="ClockOutline"
                                                     Width="22" Height="22"
                                                     Foreground="{StaticResource AuraAmber}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Last Cleaned" FontSize="12"
                                       Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding LastCleanedDisplay}"
                                       FontSize="17" FontWeight="SemiBold"
                                       Foreground="{StaticResource AuraTextBright}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ── SYSTEM INFO STRIP ── -->
            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                    CornerRadius="12"
                    Background="{StaticResource AuraSurface}"
                    BorderBrush="{StaticResource AuraBorder}" BorderThickness="1"
                    Padding="0">
                <Grid>
                    <!-- Subtle gradient top edge -->
                    <Rectangle Height="1" VerticalAlignment="Top" Opacity="0.4" RadiusX="6" RadiusY="6">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="{StaticResource AuraVioletColor}" Offset="0" />
                                <GradientStop Color="{StaticResource AuraCyanColor}" Offset="0.5" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <UniformGrid Rows="1" Margin="6,12">
                        <!-- OS -->
                        <StackPanel Margin="16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <materialDesign:PackIcon Kind="MicrosoftWindows" Width="13" Height="13"
                                                         Foreground="{StaticResource AuraTextMuted}"
                                                         VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="OS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource AuraTextMuted}" />
                            </StackPanel>
                            <TextBlock Text="{Binding OsName}"
                                       Foreground="{StaticResource AuraTextPrimary}"
                                       FontSize="11.5" TextTrimming="CharacterEllipsis" MaxWidth="180" />
                        </StackPanel>

                        <!-- CPU -->
                        <StackPanel Margin="16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <materialDesign:PackIcon Kind="Chip" Width="13" Height="13"
                                                         Foreground="{StaticResource AuraTextMuted}"
                                                         VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="CPU" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource AuraTextMuted}" />
                            </StackPanel>
                            <TextBlock Text="{Binding CpuName}"
                                       Foreground="{StaticResource AuraTextPrimary}"
                                       FontSize="11.5" TextTrimming="CharacterEllipsis" MaxWidth="180" />
                        </StackPanel>

                        <!-- RAM -->
                        <StackPanel Margin="16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <materialDesign:PackIcon Kind="Memory" Width="13" Height="13"
                                                         Foreground="{StaticResource AuraTextMuted}"
                                                         VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="RAM" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource AuraTextMuted}" />
                            </StackPanel>
                            <TextBlock Text="{Binding TotalRam}"
                                       Foreground="{StaticResource AuraTextBright}"
                                       FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>

                        <!-- Uptime -->
                        <StackPanel Margin="16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <materialDesign:PackIcon Kind="TimerOutline" Width="13" Height="13"
                                                         Foreground="{StaticResource AuraTextMuted}"
                                                         VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="UPTIME" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource AuraTextMuted}" />
                            </StackPanel>
                            <TextBlock Text="{Binding SystemUptime}"
                                       Foreground="{StaticResource AuraTextBright}"
                                       FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ ACTION BUTTONS ═══ -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,24,0,0">
            <!-- Primary row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Button Style="{StaticResource AuraPrimaryButton}"
                        Command="{Binding QuickAnalyzeCommand}"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White" />
                        <TextBlock Text="ANALYZE SYSTEM" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="SemiBold" Foreground="White" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource AuraOutlinedButton}"
                        Command="{Binding QuickCleanCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Broom" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="QUICK CLEAN" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Secondary row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource AuraGhostButton}"
                        Command="{Binding BoostMemoryCommand}"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="RocketLaunch" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="BOOST RAM" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource AuraGhostButton}"
                        Command="{Binding NavigateToCommand}"
                        CommandParameter="StorageMap">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartDonut" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="STORAGE MAP" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- ═══ CONTEXT MENU TOGGLE ═══ -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,16,0,0" Orientation="Horizontal">
            <TextBlock Text="Explorer Context Menu:"
                       Foreground="{StaticResource AuraTextMuted}" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="{Binding ContextMenuStatus}"
                       Foreground="{StaticResource AuraTextSecondary}" FontSize="11"
                       FontWeight="Medium" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>