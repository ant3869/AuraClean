<UserControl x:Class="AuraClean.Views.FileRecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{DynamicResource AuraTextBright}">
                <Run Text="File " /><Run Text="Recovery" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Recover recently deleted files from the Recycle Bin"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Action Bar -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Scan Button -->
                <Button Grid.Column="0"
                        Style="{StaticResource AuraPrimaryButton}"
                        Command="{Binding ScanRecycleBinCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Padding="20,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Scan Recycle Bin" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Restore Button -->
                <Button Grid.Column="1" Margin="8,0,0,0"
                        Style="{StaticResource AuraSecondaryButton}"
                        Command="{Binding RestoreSelectedCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Padding="20,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileRestore" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Restore Selected" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Select All / Deselect All -->
                <Button Grid.Column="2" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding SelectAllCommand}"
                        Content="Select All" Padding="14,8" Margin="16,0,0,0" />

                <Button Grid.Column="3" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding DeselectAllCommand}"
                        Content="Deselect All" Padding="14,8" Margin="4,0,0,0" />

                <!-- Progress -->
                <ProgressBar Grid.Column="4" IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Margin="16,0,0,0" VerticalAlignment="Center"
                             Foreground="{StaticResource AuraAccentTeal}" />

                <!-- Cancel -->
                <Button Grid.Column="5" Style="{StaticResource AuraGhostButton}"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                        Content="Cancel" Padding="14,8" Margin="8,0,0,0" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Grid Grid.Row="2" Margin="0,0,0,12"
              Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Total count -->
            <Border Grid.Column="0" Style="{StaticResource AuraGlassCard}"
                    Padding="14,8" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DeleteRestore" Foreground="{StaticResource AuraAccentPurple}"
                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding TotalItems}" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource AuraTextPrimary}" VerticalAlignment="Center" />
                    <TextBlock Text=" items" Foreground="{DynamicResource AuraTextSecondary}"
                               VerticalAlignment="Center" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Type Filter -->
            <ComboBox Grid.Column="1" ItemsSource="{Binding FileTypes}"
                      SelectedItem="{Binding FilterType}"
                      Background="{DynamicResource AuraSurfaceLight}"
                      Foreground="{DynamicResource AuraTextPrimary}"
                      FontSize="12" Width="130" Margin="0,0,8,0" />

            <!-- Search -->
            <TextBox Grid.Column="2"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Filter by name or path..."
                     Background="{DynamicResource AuraSurfaceLight}"
                     Foreground="{DynamicResource AuraTextPrimary}"
                     FontSize="12" Padding="8,6" />
        </Grid>

        <!-- File DataGrid -->
        <Grid Grid.Row="3">
            <DataGrid ItemsSource="{Binding FilteredFiles}"
                  SelectedItem="{Binding SelectedFile}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserAddRows="False"
                  SelectionMode="Extended"
                  Background="Transparent"
                  Foreground="{DynamicResource AuraTextPrimary}"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource AuraBorderSubtle}"
                  RowBackground="Transparent"
                  AlternatingRowBackground="{StaticResource AuraOverlayFaint}"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <!-- Checkbox -->
                <DataGridTemplateColumn Width="42">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      AutomationProperties.Name="Select File for Recovery"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- File Name -->
                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextPrimary}" />

                <!-- Type -->
                <DataGridTextColumn Header="Type" Binding="{Binding FileType}" Width="80"
                                    IsReadOnly="True"
                                    Foreground="{StaticResource AuraAccentTeal}" />

                <!-- Size -->
                <DataGridTextColumn Header="Size" Binding="{Binding FormattedSize}" Width="100"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextSecondary}"
                                    SortMemberPath="SizeBytes" />

                <!-- Deleted Date -->
                <DataGridTextColumn Header="Deleted" Binding="{Binding DeletedDateDisplay}" Width="140"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextSecondary}"
                                    SortMemberPath="DeletedDate" />

                <!-- Original Path -->
                <DataGridTextColumn Header="Original Location" Binding="{Binding OriginalPath}" Width="300"
                                    IsReadOnly="True"
                                    Foreground="{DynamicResource AuraTextMuted}" />
            </DataGrid.Columns>
        </DataGrid>

            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasResults}" Value="False" />
                                    <Condition Binding="{Binding IsBusy}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="DeleteRestore"
                                         Width="48" Height="48"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource AuraTextMuted}" />
                <TextBlock Text="No recoverable files"
                           FontSize="15" Margin="0,10,0,4"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AuraTextSecondary}" />
                <TextBlock Text="Scan the Recycle Bin to find files that can be restored"
                           FontSize="12" HorizontalAlignment="Center"
                           Foreground="{DynamicResource AuraTextMuted}" />
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Margin="0,12,0,0" Padding="8,8"
                Background="{DynamicResource AuraSurfaceLight}" CornerRadius="8">
            <TextBlock Text="{Binding StatusMessage}"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="12" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
