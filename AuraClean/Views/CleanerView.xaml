<UserControl x:Class="AuraClean.Views.CleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{DynamicResource AuraTextBright}">
                <Run Text="System " /><Run Text="Cleaner" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Find and remove temporary files, old caches, and leftover data from your system"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Action Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,12"
              helpers:AnimationHelper.AnimateOnVisible="True"
              helpers:AnimationHelper.StaggerIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="ANALYZE"
                    Style="{StaticResource AuraPrimaryButton}"
                    Command="{Binding AnalyzeCommand}"
                    Margin="0,0,12,0">
            </Button>

            <!-- Summary text -->
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding StatusMessage}" />
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Button Grid.Column="2"
                    Content="Select All"
                    Style="{StaticResource AuraGhostButton}"
                    Foreground="{StaticResource AuraAccentTeal}"
                    Command="{Binding SelectAllCommand}"
                    Margin="0,0,4,0" />

            <Button Grid.Column="3"
                    Content="Deselect All"
                    Style="{StaticResource AuraGhostButton}"
                    Command="{Binding DeselectAllCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="4"
                    Style="{StaticResource AuraOutlinedButton}"
                    Command="{Binding CleanSelectedCommand}"
                    Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Broom" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="CLEAN SELECTED" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Progress bar during analysis -->
        <ProgressBar Grid.Row="1"
                     Value="{Binding ProgressValue}"
                     Minimum="0" Maximum="100"
                     Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}"
                     Foreground="{StaticResource AuraAccentPurple}"
                     Height="4"
                     VerticalAlignment="Bottom"
                     Margin="0,0,0,-8"
                     helpers:AnimationHelper.SmoothProgress="True" />

        <!-- Empty state -->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding HasResults}" Value="False" />
                                <Condition Binding="{Binding IsAnalyzing}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <materialDesign:PackIcon Kind="Broom"
                                     Width="48" Height="48"
                                     HorizontalAlignment="Center"
                                     Foreground="{DynamicResource AuraTextMuted}" />
            <TextBlock Text="No junk detected"
                       FontSize="15" Margin="0,10,0,4"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AuraTextSecondary}" />
            <TextBlock Text="Run a system scan to find cleanable files"
                       FontSize="12" HorizontalAlignment="Center"
                       Foreground="{DynamicResource AuraTextMuted}" />
            <Button Content="ANALYZE" Margin="0,16,0,0"
                    Style="{StaticResource AuraPrimaryButton}"
                    Command="{Binding AnalyzeCommand}"
                    HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Categorized Junk List -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource AuraGlassCardFlush}" CornerRadius="8"
                                Margin="0,0,0,8">
                            <Expander IsExpanded="{Binding IsExpanded}"
                                      Foreground="{DynamicResource AuraTextPrimary}">
                                <Expander.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsAllSelected}"
                                                  AutomationProperties.Name="Select All Cleanup Results"
                                                  Margin="0,0,12,0"
                                                  VerticalAlignment="Center" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource AuraTextPrimary}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ItemCount, StringFormat='{}{0} items'}"
                                                   Foreground="{DynamicResource AuraTextSecondary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0" />

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding FormattedTotalSize}"
                                                   Foreground="{StaticResource AuraAccentTeal}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Expander.Header>

                                <ItemsControl ItemsSource="{Binding Items}"
                                              Margin="40,0,16,8"
                                              VirtualizingStackPanel.IsVirtualizing="True"
                                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                                              ScrollViewer.CanContentScroll="True"
                                              MaxHeight="400">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.Template>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <ScrollViewer CanContentScroll="True"
                                                          VerticalScrollBarVisibility="Auto"
                                                          Focusable="False">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource AuraBorder}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="4,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsSelected}"
                                                              AutomationProperties.Name="Select Cleanup Item"
                                                              Margin="0,0,8,0"
                                                              VerticalAlignment="Center" />

                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="{DynamicResource AuraTextPrimary}"
                                                                   FontSize="13"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Path}"
                                                                   Foreground="{DynamicResource AuraTextSecondary}"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <!-- Lock indicator -->
                                                    <materialDesign:PackIcon Grid.Column="2"
                                                                             Kind="Lock"
                                                                             Foreground="{StaticResource AuraWarning}"
                                                                             Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}"
                                                                             ToolTip="{Binding LockingProcess, StringFormat='Locked by: {0}'}"
                                                                             VerticalAlignment="Center"
                                                                             Margin="8,0" />

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding FormattedSize}"
                                                               Foreground="{StaticResource AuraAccentTeal}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               MinWidth="60"
                                                               TextAlignment="Right" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="3" Style="{StaticResource AuraGlassCardCompact}"
                CornerRadius="6" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           AutomationProperties.LiveSetting="Polite"
                           Foreground="{DynamicResource AuraTextSecondary}"
                           FontSize="12"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding TotalJunkCount, StringFormat='{}{0} items'}"
                               Foreground="{DynamicResource AuraTextSecondary}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />
                    <TextBlock Text="{Binding FormattedTotalSize}"
                               Foreground="{StaticResource AuraAccentPurple}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
