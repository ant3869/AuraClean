<UserControl x:Class="AuraClean.Views.DuplicateFinderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             xmlns:helpers="clr-namespace:AuraClean.Helpers">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16"
                    helpers:AnimationHelper.AnimateOnVisible="True"
                    helpers:AnimationHelper.StaggerIndex="0">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{DynamicResource AuraTextBright}">
                <Run Text="Duplicate " /><Run Text="Finder" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Find identical copies of files wasting disk space and choose which to keep"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Path selection -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding QuickPaths}"
                              SelectedItem="{Binding SelectedPath}"
                              materialDesign:HintAssist.Hint="Quick Path"
                              Width="200"
                              Foreground="{DynamicResource AuraTextPrimary}"
                              Margin="0,0,12,0" />

                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Or enter path to scan..."
                             Foreground="{DynamicResource AuraTextPrimary}"
                             Margin="0,0,12,0" />

                    <Button Grid.Column="2"
                            Content="SCAN"
                            Style="{StaticResource AuraPrimaryButton}"
                            Padding="24,8"
                            Command="{Binding ScanCommand}"
                            Margin="0,0,8,0" />

                    <Button Grid.Column="3"
                            Content="CANCEL"
                            Style="{StaticResource AuraOutlinedButton}"
                            BorderBrush="{StaticResource AuraWarning}"
                            Foreground="{StaticResource AuraWarning}"
                            Command="{Binding CancelScanCommand}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                </Grid>

                <!-- Options row -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Recursive" IsChecked="{Binding Recursive}"
                              AutomationProperties.Name="Scan Recursively"
                              Foreground="{DynamicResource AuraTextPrimary}" Margin="0,0,20,0" />

                    <TextBlock Text="Min:" Foreground="{DynamicResource AuraTextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox Text="{Binding MinSizeKB}" Width="60" Margin="0,0,4,0"
                             Foreground="{DynamicResource AuraTextPrimary}" />
                    <TextBlock Text="KB" Foreground="{DynamicResource AuraTextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,16,0" />

                    <TextBlock Text="Max:" Foreground="{DynamicResource AuraTextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox Text="{Binding MaxSizeMB}" Width="60" Margin="0,0,4,0"
                             Foreground="{DynamicResource AuraTextPrimary}" />
                    <TextBlock Text="MB" Foreground="{DynamicResource AuraTextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,16,0" />

                    <TextBlock Text="Extensions:" Foreground="{DynamicResource AuraTextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox Text="{Binding ExtensionFilter, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="e.g. jpg,png,mp3"
                             Width="180"
                             Foreground="{DynamicResource AuraTextPrimary}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results Area -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasResults}" Value="False" />
                                    <Condition Binding="{Binding IsBusy}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="ContentDuplicate"
                                         Width="48" Height="48"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource AuraTextMuted}" />
                <TextBlock Text="No duplicates found"
                           FontSize="15" Margin="0,10,0,4"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AuraTextSecondary}" />
                <TextBlock Text="Select a directory and start a scan to find duplicate files"
                           FontSize="12" HorizontalAlignment="Center"
                           Foreground="{DynamicResource AuraTextMuted}" />
            </StackPanel>

            <!-- Loading state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True" Width="64" Height="64"
                             Foreground="{StaticResource AuraAccentPurple}" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="14"
                           Foreground="{DynamicResource AuraTextSecondary}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"
                           TextWrapping="Wrap" MaxWidth="400" TextAlignment="Center" />
            </StackPanel>

            <!-- Results -->
            <Grid Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Summary Cards -->
                <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                    <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentDuplicate" Foreground="{StaticResource AuraAccentPurple}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Foreground="{DynamicResource AuraTextSecondary}" VerticalAlignment="Center">
                                <Run Text="Groups: " />
                                <Run Text="{Binding TotalGroupCount, Mode=OneWay}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource AuraTextPrimary}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileMultiple" Foreground="{StaticResource AuraWarning}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Foreground="{DynamicResource AuraTextSecondary}" VerticalAlignment="Center">
                                <Run Text="Duplicates: " />
                                <Run Text="{Binding TotalDuplicateCount, Mode=OneWay}" FontWeight="SemiBold"
                                     Foreground="{StaticResource AuraWarning}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AuraGlassCardCompact}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Harddisk" Foreground="{StaticResource AuraAccentTeal}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Foreground="{DynamicResource AuraTextSecondary}" VerticalAlignment="Center">
                                <Run Text="Wasted: " />
                                <Run Text="{Binding FormattedWasted, Mode=OneWay}" FontWeight="SemiBold"
                                     Foreground="{StaticResource AuraAccentTeal}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource AuraGlassCardCompact}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Timer" Foreground="{StaticResource AuraAccentPurple}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Foreground="{DynamicResource AuraTextSecondary}" VerticalAlignment="Center">
                                <Run Text="Scan: " />
                                <Run Text="{Binding ScanDuration, Mode=OneWay}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource AuraTextPrimary}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Select All Duplicates"
                            Style="{StaticResource AuraGhostButton}"
                            Foreground="{StaticResource AuraAccentTeal}"
                            Command="{Binding SelectAllDuplicatesCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Deselect All"
                            Style="{StaticResource AuraGhostButton}"
                            Command="{Binding DeselectAllCommand}"
                            Margin="0,0,8,0" />
                    <Button Style="{StaticResource AuraOutlinedButton}"
                            BorderBrush="{StaticResource AuraWarning}"
                            Foreground="{StaticResource AuraWarning}"
                            Padding="16,8"
                            Command="{Binding DeleteSelectedCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="DELETE SELECTED" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Duplicate Groups List -->
                <ItemsControl Grid.Row="2" ItemsSource="{Binding DuplicateGroups}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto"
                                          Padding="{TemplateBinding Padding}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource AuraGlassCardFlush}" CornerRadius="8"
                                        Margin="0,0,0,8">
                                    <Expander IsExpanded="True" Foreground="{DynamicResource AuraTextPrimary}">
                                        <Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" FontSize="14" FontWeight="Medium"
                                                           Foreground="{DynamicResource AuraTextPrimary}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="{Binding Count, Mode=OneWay}" />
                                                    <Run Text=" identical files" />
                                                </TextBlock>

                                                <TextBlock Grid.Column="1" Text="{Binding FormattedSize}"
                                                           Foreground="{DynamicResource AuraTextSecondary}"
                                                           VerticalAlignment="Center" Margin="0,0,16,0" FontSize="13" />

                                                <TextBlock Grid.Column="2" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AuraWarning}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Run Text="Wasted: " />
                                                    <Run Text="{Binding FormattedWasted, Mode=OneWay}" />
                                                </TextBlock>

                                                <TextBlock Grid.Column="3" Text="{Binding Hash}"
                                                           Foreground="{DynamicResource AuraTextMuted}" FontSize="11" FontFamily="Consolas"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Hash}" MaxWidth="200" />
                                            </Grid>
                                        </Expander.Header>

                                        <ItemsControl ItemsSource="{Binding Files}" Margin="40,0,16,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource AuraBorder}" BorderThickness="0,0,0,1" Padding="4,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsSelected}"
                                                                      AutomationProperties.Name="Select Duplicate File"
                                                                      Margin="0,0,8,0" VerticalAlignment="Center" />

                                                            <!-- Keep badge -->
                                                            <Border Grid.Column="1"
                                                                    Background="{StaticResource AuraSuccessTint}" CornerRadius="4"
                                                                    Padding="6,2" Margin="0,0,8,0"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding IsKeep, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="KEEP" FontSize="10" FontWeight="Bold"
                                                                           Foreground="{StaticResource AuraSuccess}" />
                                                            </Border>

                                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FileName}"
                                                                           Foreground="{DynamicResource AuraTextPrimary}"
                                                                           FontSize="13" TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{Binding FileName}" />
                                                                <TextBlock Text="{Binding Directory}"
                                                                           Foreground="{DynamicResource AuraTextSecondary}"
                                                                           FontSize="11" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>

                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding LastModified, StringFormat={}{0:yyyy-MM-dd}}"
                                                                       Foreground="{DynamicResource AuraTextSecondary}"
                                                                       FontSize="11" VerticalAlignment="Center"
                                                                       Margin="8,0" />

                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding FormattedSize}"
                                                                       Foreground="{StaticResource AuraAccentTeal}"
                                                                       FontSize="12" VerticalAlignment="Center"
                                                                       MinWidth="60" TextAlignment="Right" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Style="{StaticResource AuraGlassCardCompact}"
                CornerRadius="6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="12" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
