<UserControl x:Class="AuraClean.Views.InstallMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="26" FontWeight="Light"
                       Foreground="{StaticResource AuraTextBright}">
                <Run Text="Install " /><Run Text="Monitor" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Text="Shadow snapshot — track what programs install for surgical removal later"
                       Foreground="{StaticResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Monitor Controls -->
        <materialDesign:Card Grid.Row="1" Background="{StaticResource AuraSurface}"
                             UniformCornerRadius="12" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <!-- Program Name Input -->
                    <TextBox materialDesign:HintAssist.Hint="Program name to monitor (e.g., 'Adobe Photoshop')"
                             materialDesign:HintAssist.IsFloating="True"
                             Text="{Binding ProgramLabel, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsMonitoring, Converter={StaticResource InverseBool}}"
                             Foreground="{StaticResource AuraTextPrimary}"
                             FontSize="14" Margin="0,0,16,12" />

                    <!-- Dry Run Toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="{Binding IsDryRun}" Margin="0,0,8,0" />
                        <TextBlock Text="Dry Run" Foreground="{StaticResource AuraTextSecondary}"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Start Monitoring Button -->
                    <Button Content="START MONITORING"
                            Style="{StaticResource AuraPrimaryButton}"
                            Padding="24,10"
                            Command="{Binding StartMonitoringCommand}"
                            Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                            Margin="0,0,0,8" />

                    <!-- Stop Monitoring Button -->
                    <Button Content="STOP &amp; COMPARE"
                            Style="{StaticResource AuraOutlinedButton}"
                            Foreground="{StaticResource AuraSuccess}"
                            BorderBrush="{StaticResource AuraSuccess}"
                            Padding="24,10"
                            Command="{Binding StopMonitoringCommand}"
                            Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,4" />

                    <Button Content="Cancel"
                            Style="{StaticResource AuraOutlinedButton}"
                            BorderBrush="{StaticResource AuraWarning}"
                            Foreground="{StaticResource AuraWarning}"
                            Command="{Binding CancelMonitoringCommand}"
                            Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Monitoring Indicator & Results -->
        <Grid Grid.Row="2">
            <!-- Active Monitoring Indicator -->
            <materialDesign:Card Background="{StaticResource AuraSurface}"
                                 UniformCornerRadius="12" Padding="24"
                                 Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Width="64" Height="64"
                                 Foreground="{StaticResource AuraAccentPurple}"
                                 HorizontalAlignment="Center" />
                    <TextBlock Text="Monitoring Active" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AuraAccentPurple}"
                               HorizontalAlignment="Center" Margin="0,16,0,4" />
                    <TextBlock Text="Install your software now, then click 'Stop &amp; Compare'"
                               Foreground="{StaticResource AuraTextSecondary}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Delta Results -->
            <StackPanel Visibility="{Binding HasDelta, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Last Capture Results" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource AuraTextPrimary}" Margin="0,0,0,12" />

                <WrapPanel>
                    <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                         UniformCornerRadius="12" Padding="16" Margin="0,0,12,12" Width="180">
                        <StackPanel>
                            <TextBlock Text="Registry Keys" FontSize="12" Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding NewRegistryKeysCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AuraAccentPurple}" />
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                         UniformCornerRadius="12" Padding="16" Margin="0,0,12,12" Width="180">
                        <StackPanel>
                            <TextBlock Text="New Files" FontSize="12" Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding NewFilesCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AuraAccentTeal}" />
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                         UniformCornerRadius="12" Padding="16" Margin="0,0,12,12" Width="180">
                        <StackPanel>
                            <TextBlock Text="Total Size" FontSize="12" Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding FormattedNewFileSize}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AuraWarning}" />
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Background="{StaticResource AuraSurfaceLight}"
                                         UniformCornerRadius="12" Padding="16" Margin="0,0,12,12" Width="180">
                        <StackPanel>
                            <TextBlock Text="Directories" FontSize="12" Foreground="{StaticResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding NewDirectoriesCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AuraAccentPurple}" />
                        </StackPanel>
                    </materialDesign:Card>
                </WrapPanel>

                <!-- Saved Snapshots -->
                <TextBlock Text="Saved Snapshots" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource AuraTextPrimary}" Margin="0,16,0,8" />

                <DataGrid ItemsSource="{Binding SavedSnapshots}"
                          SelectedItem="{Binding SelectedSnapshot}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent"
                          Foreground="{StaticResource AuraTextPrimary}"
                          RowBackground="{StaticResource AuraSurface}"
                          AlternatingRowBackground="{StaticResource AuraSurfaceLight}"
                          BorderThickness="0" MaxHeight="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*" />
                        <DataGridTextColumn Header="Date" Binding="{Binding FormattedTimestamp}" Width="140" />
                        <DataGridCheckBoxColumn Header="Has Report" Binding="{Binding HasDelta}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Delete Selected"
                        Style="{StaticResource AuraOutlinedButton}"
                        BorderBrush="{StaticResource AuraWarning}"
                        Foreground="{StaticResource AuraWarning}"
                        Padding="12,6"
                        Command="{Binding DeleteSnapshotCommand}"
                        HorizontalAlignment="Left" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="{StaticResource AuraTextSecondary}"
                   FontSize="13" Margin="0,12,0,0" TextWrapping="Wrap" />
    </Grid>
</UserControl>
