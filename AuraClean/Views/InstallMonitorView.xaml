<UserControl x:Class="AuraClean.Views.InstallMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{StaticResource AuraAccentPurple}"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock FontSize="26" FontWeight="Light"
                           Foreground="{DynamicResource AuraTextBright}">
                    <Run Text="Install " /><Run Text="Monitor" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
            <TextBlock Text="Record what a program adds to your system so you can fully remove it later"
                       Foreground="{DynamicResource AuraTextSecondary}"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Monitor Controls -->
        <Border Grid.Row="1" Style="{StaticResource AuraGlassCard}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <!-- Program Name Input -->
                    <TextBox materialDesign:HintAssist.Hint="Program name to monitor (e.g., 'Adobe Photoshop')"
                             materialDesign:HintAssist.IsFloating="True"
                             Text="{Binding ProgramLabel, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsMonitoring, Converter={StaticResource InverseBoolConverter}}"
                             Foreground="{DynamicResource AuraTextPrimary}"
                             FontSize="14" Margin="0,0,16,12" />

                    <!-- Dry Run Toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      AutomationProperties.Name="Dry Run"
                                      IsChecked="{Binding IsDryRun}" Margin="0,0,8,0" />
                        <TextBlock Text="Dry Run" Foreground="{DynamicResource AuraTextSecondary}"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Start Monitoring Button -->
                    <Button Content="START MONITORING"
                            Style="{StaticResource AuraPrimaryButton}"
                            Padding="24,10"
                            Command="{Binding StartMonitoringCommand}"
                            Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                            Margin="0,0,0,8" />

                    <!-- Stop Monitoring Button -->
                    <Button Content="STOP &amp; COMPARE"
                            Style="{StaticResource AuraOutlinedButton}"
                            Foreground="{StaticResource AuraSuccess}"
                            BorderBrush="{StaticResource AuraSuccess}"
                            Padding="24,10"
                            Command="{Binding StopMonitoringCommand}"
                            Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,4" />

                    <Button Content="Cancel"
                            Style="{StaticResource AuraOutlinedButton}"
                            BorderBrush="{StaticResource AuraWarning}"
                            Foreground="{StaticResource AuraWarning}"
                            Command="{Binding CancelMonitoringCommand}"
                            Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Monitoring Indicator & Results -->
        <Grid Grid.Row="2">
            <!-- Active Monitoring Indicator -->
            <Border Style="{StaticResource AuraGlassCard}"
                    Padding="24"
                    Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Width="64" Height="64"
                                 Foreground="{StaticResource AuraAccentPurple}"
                                 HorizontalAlignment="Center" />
                    <TextBlock Text="Monitoring Active" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AuraAccentPurple}"
                               HorizontalAlignment="Center" Margin="0,16,0,4" />
                    <TextBlock Text="Install your software now, then click 'Stop &amp; Compare'"
                               Foreground="{DynamicResource AuraTextSecondary}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Delta Results -->
            <StackPanel Visibility="{Binding HasDelta, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Last Capture Results" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource AuraTextPrimary}" Margin="0,0,0,12" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Hero stat: Registry Keys -->
                    <Border Grid.Column="0" Style="{StaticResource AuraGlassCard}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource AuraAccentPurple}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Registry Keys" FontSize="12" Foreground="{DynamicResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding NewRegistryKeysCount}" FontSize="32" FontWeight="Bold"
                                       FontFamily="{DynamicResource AuraFontFamilyMono}"
                                       Foreground="{StaticResource AuraAccentPurple}" Margin="0,4,0,2" />
                            <TextBlock Text="new entries detected" FontSize="11" Foreground="{DynamicResource AuraTextMuted}" />
                        </StackPanel>
                    </Border>

                    <!-- Compact: New Files -->
                    <Border Grid.Column="2" Style="{StaticResource AuraGlassCardCompact}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource AuraAccentPurple}"
                            Padding="14,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="New Files" FontSize="11" Foreground="{DynamicResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding NewFilesCount}" FontSize="22" FontWeight="Bold"
                                       FontFamily="{DynamicResource AuraFontFamilyMono}"
                                       Foreground="{StaticResource AuraAccentTeal}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Compact: Total Size -->
                    <Border Grid.Column="4" Style="{StaticResource AuraGlassCardCompact}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource AuraAccentPurple}"
                            Padding="14,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Total Size" FontSize="11" Foreground="{DynamicResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding FormattedNewFileSize}" FontSize="22" FontWeight="Bold"
                                       FontFamily="{DynamicResource AuraFontFamilyMono}"
                                       Foreground="{StaticResource AuraWarning}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Compact: Directories -->
                    <Border Grid.Column="6" Style="{StaticResource AuraGlassCardCompact}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource AuraAccentPurple}"
                            Padding="14,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Directories" FontSize="11" Foreground="{DynamicResource AuraTextSecondary}" />
                            <TextBlock Text="{Binding NewDirectoriesCount}" FontSize="22" FontWeight="Bold"
                                       FontFamily="{DynamicResource AuraFontFamilyMono}"
                                       Foreground="{StaticResource AuraAccentPurple}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Saved Snapshots -->
                <TextBlock Text="Saved Snapshots" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource AuraTextPrimary}" Margin="0,16,0,8" />

                <DataGrid ItemsSource="{Binding SavedSnapshots}"
                          SelectedItem="{Binding SelectedSnapshot}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent"
                          Foreground="{DynamicResource AuraTextPrimary}"
                          RowBackground="{DynamicResource AuraSurface}"
                          AlternatingRowBackground="{DynamicResource AuraSurfaceLight}"
                          BorderThickness="0" MaxHeight="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*" />
                        <DataGridTextColumn Header="Date" Binding="{Binding FormattedTimestamp}" Width="140" />
                        <DataGridCheckBoxColumn Header="Has Report" Binding="{Binding HasDelta}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Delete Selected"
                        Style="{StaticResource AuraOutlinedButton}"
                        BorderBrush="{StaticResource AuraWarning}"
                        Foreground="{StaticResource AuraWarning}"
                        Padding="12,6"
                        Command="{Binding DeleteSnapshotCommand}"
                        HorizontalAlignment="Left" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   AutomationProperties.LiveSetting="Polite"
                   Foreground="{DynamicResource AuraTextSecondary}"
                   FontSize="13" Margin="0,12,0,0" TextWrapping="Wrap" />
    </Grid>
</UserControl>
