                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════════ -->
    <!--  2b. CHECKBOX touch-target                  -->
    <!-- ═══════════════════════════════════════════ -->

    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>


    <!-- ═══════════════════════════════════════════ -->
    <!--  3. CARDS                                   -->
    <!-- ═══════════════════════════════════════════ -->

    <!-- Standard card: general-purpose container -->
    <Style x:Key="AuraGlassCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AuraSurface}" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource AuraBorderColor}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AuraRadiusXL}" />
        <Setter Property="Padding" Value="20" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#3A8B7AE8" Duration="0:0:0.25">
                            <ColorAnimation.EasingFunction>
                                <QuarticEase EasingMode="EaseOut" />
                            </ColorAnimation.EasingFunction>
                        </ColorAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="{StaticResource AuraBorderColor}" Duration="0:0:0.2">
                            <ColorAnimation.EasingFunction>
                                <QuarticEase EasingMode="EaseOut" />
                            </ColorAnimation.EasingFunction>
                        </ColorAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Compact card: stat chips, summary badges, status bars -->
    <Style x:Key="AuraGlassCardCompact" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AuraSurfaceLight}" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource AuraBorderColor}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AuraRadiusM}" />
        <Setter Property="Padding" Value="14,8" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#3A8B7AE8" Duration="0:0:0.25">
                            <ColorAnimation.EasingFunction>
                                <QuarticEase EasingMode="EaseOut" />
                            </ColorAnimation.EasingFunction>
                        </ColorAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="{StaticResource AuraBorderColor}" Duration="0:0:0.2">
                            <ColorAnimation.EasingFunction>
                                <QuarticEase EasingMode="EaseOut" />
                            </ColorAnimation.EasingFunction>
                        </ColorAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Flush card: list containers, data grids (no inner padding) -->
    <Style x:Key="AuraGlassCardFlush" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AuraSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AuraBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AuraRadiusXL}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Section card: standard card with bottom margin for vertical stacking -->
    <Style x:Key="AuraSectionCard" TargetType="Border" BasedOn="{StaticResource AuraGlassCard}">
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>


    <!-- ═══════════════════════════════════════════ -->
    <!--  4. INPUTS                                  -->
    <!-- ═══════════════════════════════════════════ -->

    <!-- Search box: rounded input with surface background -->
    <Style x:Key="AuraSearchBox" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource AuraSurfaceLight}" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AuraBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeBody}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AuraTextPrimary}" />
    </Style>


    <!-- ═══════════════════════════════════════════ -->
    <!--  5. TEXT STYLES                              -->
    <!--  Named styles for common text patterns.     -->
    <!-- ═══════════════════════════════════════════ -->

    <!-- Page display heading: 30pt Light, bright foreground -->
    <!-- Usage: <TextBlock Style="{StaticResource AuraPageTitle}"> ... </TextBlock> -->
    <Style x:Key="AuraPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeDisplay}" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextBright}" />
    </Style>

    <!-- Page subtitle: 13pt, secondary foreground, small top margin -->
    <Style x:Key="AuraPageSubtitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeBody}" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextSecondary}" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <!-- Section heading: 16pt SemiBold, bright foreground -->
    <Style x:Key="AuraSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeLG}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextBright}" />
    </Style>

    <!-- Label text: 12pt, secondary foreground -->
    <Style x:Key="AuraLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeLabel}" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextSecondary}" />
    </Style>

    <!-- Body text: 13pt, primary foreground -->
    <Style x:Key="AuraBodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeBody}" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextPrimary}" />
    </Style>

    <!-- Stat value: 24pt SemiBold, bright foreground, mono for data -->
    <Style x:Key="AuraStatValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextBright}" />
    </Style>

    <!-- Muted text: 11pt, muted foreground -->
    <Style x:Key="AuraMutedText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeCaption}" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextMuted}" />
    </Style>

    <!-- Nav section label: 10pt SemiBold, muted, left padded -->
    <Style x:Key="AuraNavSectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeXS}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AuraTextMuted}" />
        <Setter Property="Margin" Value="28,16,0,4" />
    </Style>


    <!-- ═══════════════════════════════════════════ -->
    <!--  6. BADGES                                  -->
    <!-- ═══════════════════════════════════════════ -->

    <!-- Status badge: compact rounded label (e.g., "High", "Low") -->
    <Style x:Key="AuraStatusBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource AuraRadiusXS}" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- Chip badge: slightly larger for categories/tags -->
    <Style x:Key="AuraChip" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource AuraRadiusSM}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="{DynamicResource AuraSurfaceLight}" />
    </Style>

</ResourceDictionary>
