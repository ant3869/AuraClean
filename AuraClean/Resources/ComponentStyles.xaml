        <Setter Property="Foreground" Value="{StaticResource AuraAccentTeal}" />
        <Setter Property="BorderBrush" Value="{StaticResource AuraAccentTeal}" />
        <Setter Property="FontFamily" Value="{StaticResource AuraFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AuraFontSizeMD}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="24,10" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
