<Application x:Class="AuraClean.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design base theme -->
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="DeepPurple"
                                             SecondaryColor="Teal" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════════════════════════════════════════ -->
            <!--      OBSIDIAN AURORA — Design System v2          -->
            <!-- ═══════════════════════════════════════════════ -->

            <!-- ── Core Colors ── -->
            <Color x:Key="AuraBgColor">#080810</Color>
            <Color x:Key="AuraSurfaceColor">#0F0F1E</Color>
            <Color x:Key="AuraSurfaceLightColor">#171730</Color>
            <Color x:Key="AuraSurfaceElevatedColor">#1F1F42</Color>
            <Color x:Key="AuraVioletColor">#7C5CFC</Color>
            <Color x:Key="AuraCyanColor">#00E5C3</Color>
            <Color x:Key="AuraCoralColor">#FF6B8A</Color>
            <Color x:Key="AuraMintColor">#5BF0D7</Color>
            <Color x:Key="AuraAmberColor">#FFB74D</Color>
            <Color x:Key="AuraTextBrightColor">#F0F0FF</Color>
            <Color x:Key="AuraTextColor">#C8C8E0</Color>
            <Color x:Key="AuraTextDimColor">#7B7BA0</Color>
            <Color x:Key="AuraTextMutedColor">#3D3D5C</Color>
            <Color x:Key="AuraBorderColor">#222244</Color>
            <Color x:Key="AuraBorderSubtleColor">#1A1A36</Color>

            <!-- ── Surface Brushes ── -->
            <SolidColorBrush x:Key="AuraBackground" Color="{StaticResource AuraBgColor}" />
            <SolidColorBrush x:Key="AuraSurface" Color="{StaticResource AuraSurfaceColor}" />
            <SolidColorBrush x:Key="AuraSurfaceLight" Color="{StaticResource AuraSurfaceLightColor}" />
            <SolidColorBrush x:Key="AuraSurfaceElevated" Color="{StaticResource AuraSurfaceElevatedColor}" />

            <!-- ── Accent Brushes (backward-compatible keys) ── -->
            <SolidColorBrush x:Key="AuraAccentPurple" Color="{StaticResource AuraVioletColor}" />
            <SolidColorBrush x:Key="AuraAccentTeal" Color="{StaticResource AuraCyanColor}" />
            <SolidColorBrush x:Key="AuraWarning" Color="{StaticResource AuraCoralColor}" />
            <SolidColorBrush x:Key="AuraSuccess" Color="{StaticResource AuraMintColor}" />
            <SolidColorBrush x:Key="AuraAmber" Color="{StaticResource AuraAmberColor}" />

            <!-- ── Text Brushes ── -->
            <SolidColorBrush x:Key="AuraTextBright" Color="{StaticResource AuraTextBrightColor}" />
            <SolidColorBrush x:Key="AuraTextPrimary" Color="{StaticResource AuraTextColor}" />
            <SolidColorBrush x:Key="AuraTextSecondary" Color="{StaticResource AuraTextDimColor}" />
            <SolidColorBrush x:Key="AuraTextMuted" Color="{StaticResource AuraTextMutedColor}" />

            <!-- ── Border Brushes ── -->
            <SolidColorBrush x:Key="AuraBorder" Color="{StaticResource AuraBorderColor}" />
            <SolidColorBrush x:Key="AuraBorderSubtle" Color="{StaticResource AuraBorderSubtleColor}" />

            <!-- ── Gradient Brushes ── -->
            <LinearGradientBrush x:Key="AuraGradientAccent" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource AuraVioletColor}" Offset="0" />
                <GradientStop Color="{StaticResource AuraCyanColor}" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AuraGradientVertical" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource AuraVioletColor}" Offset="0" />
                <GradientStop Color="{StaticResource AuraCyanColor}" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AuraGradientHorizontal" StartPoint="0,0.5" EndPoint="1,0.5">
                <GradientStop Color="{StaticResource AuraVioletColor}" Offset="0" />
                <GradientStop Color="{StaticResource AuraCyanColor}" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AuraGradientWarm" StartPoint="0,0.5" EndPoint="1,0.5">
                <GradientStop Color="{StaticResource AuraCoralColor}" Offset="0" />
                <GradientStop Color="{StaticResource AuraAmberColor}" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AuraSidebarGradient" StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#0C0C1A" Offset="0" />
                <GradientStop Color="#08080F" Offset="1" />
            </LinearGradientBrush>

            <!-- ═══════════════════════════════════════════ -->
            <!--            CUSTOM NAV BUTTON               -->
            <!-- ═══════════════════════════════════════════ -->
            <Style x:Key="AuraNavButton" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource AuraTextSecondary}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Height" Value="42" />
                <Setter Property="Margin" Value="0,1" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid>
                                <Border x:Name="ActiveBar"
                                        Width="3" HorizontalAlignment="Left"
                                        CornerRadius="0,1.5,1.5,0"
                                        Opacity="0" Margin="0,8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="{StaticResource AuraVioletColor}" Offset="0" />
                                            <GradientStop Color="{StaticResource AuraCyanColor}" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border x:Name="BgSurface"
                                        Background="Transparent"
                                        CornerRadius="10"
                                        Margin="10,0,10,0"
                                        Padding="14,0">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      RecognizesAccessKey="True" />
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BgSurface" Property="Background" Value="{StaticResource AuraAccentPurpleSemi}" />
                                    <Setter Property="Foreground" Value="{StaticResource AuraTextPrimary}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ActiveBar" Property="Opacity" Value="1" />
                                    <Setter TargetName="BgSurface" Property="Background" Value="#127C5CFC" />
                                    <Setter Property="Foreground" Value="{StaticResource AuraTextBright}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════ -->
            <!--          CUSTOM BUTTON STYLES              -->
            <!-- ═══════════════════════════════════════════ -->
            <Style x:Key="AuraPrimaryButton" TargetType="Button">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Padding" Value="28,12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#7C5CFC" Offset="0" />
                                        <GradientStop Color="#6045E0" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#7C5CFC" BlurRadius="24" ShadowDepth="0" Opacity="0.3" />
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AuraSecondaryButton" TargetType="Button">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Padding" Value="24,10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="10"
                                    Background="{StaticResource AuraAccentTeal}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AuraOutlinedButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource AuraAccentTeal}" />
                <Setter Property="BorderBrush" Value="{StaticResource AuraAccentTeal}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Padding" Value="24,10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="10" Background="Transparent"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AuraOverlayLight}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AuraGhostButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource AuraTextSecondary}" />
                <Setter Property="BorderBrush" Value="{StaticResource AuraBorder}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Padding" Value="16,8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="10" Background="Transparent"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AuraOverlaySubtle}" />
                                    <Setter Property="Foreground" Value="{StaticResource AuraTextPrimary}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════ -->
            <!--             GLASS CARD STYLE               -->
            <!-- ═══════════════════════════════════════════ -->
            <Style x:Key="AuraGlassCard" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AuraSurface}" />
                <Setter Property="BorderBrush" Value="{StaticResource AuraBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <!-- Compact card for summary chips, stat badges, status bars -->
            <Style x:Key="AuraGlassCardCompact" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AuraSurfaceLight}" />
                <Setter Property="BorderBrush" Value="{StaticResource AuraBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,8" />
            </Style>

            <!-- Flush card for list containers with no inner padding -->
            <Style x:Key="AuraGlassCardFlush" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AuraSurface}" />
                <Setter Property="BorderBrush" Value="{StaticResource AuraBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <!-- ═══════════════════════════════════════════ -->
            <!--         SEMI-TRANSPARENT OVERLAYS          -->
            <!-- ═══════════════════════════════════════════ -->
            <SolidColorBrush x:Key="AuraAccentPurpleSemi" Color="#0E7C5CFC" />
            <SolidColorBrush x:Key="AuraAccentTealSemi" Color="#0E00E5C3" />
            <SolidColorBrush x:Key="AuraAmberSemi" Color="#0EFFB74D" />
            <SolidColorBrush x:Key="AuraCoralSemi" Color="#15FF6B8A" />
            <SolidColorBrush x:Key="AuraOverlayLight" Color="#0AFFFFFF" />
            <SolidColorBrush x:Key="AuraOverlaySubtle" Color="#08FFFFFF" />
            <SolidColorBrush x:Key="AuraOverlayFaint" Color="#06FFFFFF" />
            <SolidColorBrush x:Key="AuraTrackBg" Color="#10FFFFFF" />

            <!-- Badge backgrounds (~8% alpha) -->
            <SolidColorBrush x:Key="AuraAccentPurpleBadge" Color="#157C5CFC" />
            <SolidColorBrush x:Key="AuraAccentTealBadge" Color="#1500E5C3" />
            <SolidColorBrush x:Key="AuraAmberBadge" Color="#15FFB74D" />
            <SolidColorBrush x:Key="AuraBlueBadge" Color="#1564B5F6" />

            <!-- Severity backgrounds (~20% alpha) -->
            <SolidColorBrush x:Key="AuraCriticalSeverity" Color="#33FF4444" />
            <SolidColorBrush x:Key="AuraCoralSeverity" Color="#33FF6B8A" />
            <SolidColorBrush x:Key="AuraAmberSeverity" Color="#33FFB74D" />
            <SolidColorBrush x:Key="AuraSuccessSeverity" Color="#335BF0D7" />

            <!-- Global converters -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:FileSizeConverter x:Key="FileSizeConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
            <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
            <converters:TreemapColorConverter x:Key="TreemapColorConverter" />
            <converters:HexToBrushConverter x:Key="HexToBrush" />
            <converters:ScoreToWidthConverter x:Key="ScoreToWidth" />
            <converters:HealthScoreColorConverter x:Key="HealthColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
