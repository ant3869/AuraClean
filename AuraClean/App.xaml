<Application x:Class="AuraClean.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AuraClean.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design base theme -->
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="DeepPurple"
                                             SecondaryColor="Teal" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />

                <!-- AuraClean Design System -->
                <ResourceDictionary Source="Resources/DesignTokens.xaml" />
                <ResourceDictionary Source="Resources/ComponentStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:FileSizeConverter x:Key="FileSizeConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
            <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
            <converters:TreemapColorConverter x:Key="TreemapColorConverter" />
            <converters:HexToBrushConverter x:Key="HexToBrush" />
            <converters:ScoreToWidthConverter x:Key="ScoreToWidth" />
            <converters:HealthScoreColorConverter x:Key="HealthColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
